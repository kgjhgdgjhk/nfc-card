<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'لوحة التحكم - NFC Pro' %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: #f4f9fe;
            color: #1e293b;
            min-height: 100vh;
            position: relative;
        }

        /* خلفية متحركة فاتحة */
        .background {
            position: fixed;
            width: 100vw;
            height: 100vh;
            top: 0;
            left: 0;
            z-index: -1;
            overflow: hidden;
        }

        .gradient-orb {
            position: absolute;
            width: 80vmax;
            height: 80vmax;
            background: radial-gradient(circle at 30% 50%, rgba(147, 197, 253, 0.5) 0%, rgba(165, 180, 252, 0.4) 50%, transparent 70%);
            border-radius: 50%;
            top: -20%;
            right: -20%;
            animation: floatOrb 30s ease-in-out infinite;
        }

        .gradient-orb-2 {
            position: absolute;
            width: 70vmax;
            height: 70vmax;
            background: radial-gradient(circle at 70% 50%, rgba(216, 180, 254, 0.4) 0%, rgba(187, 222, 252, 0.4) 50%, transparent 70%);
            border-radius: 50%;
            bottom: -20%;
            left: -20%;
            animation: floatOrb 35s ease-in-out infinite reverse;
        }

        @keyframes floatOrb {
            0%, 100% { transform: translate(0, 0) scale(1); }
            50% { transform: translate(-5%, 5%) scale(1.05); }
        }

        .particles {
            position: absolute;
            width: 100%;
            height: 100%;
            background-image: 
                radial-gradient(circle at 20% 30%, rgba(59, 130, 246, 0.06) 1.5px, transparent 1.5px),
                radial-gradient(circle at 80% 70%, rgba(139, 92, 246, 0.05) 1px, transparent 1px);
            background-size: 130px 130px;
            animation: moveParticles 50s linear infinite;
            opacity: 0.4;
        }

        @keyframes moveParticles {
            0% { background-position: 0 0, 0 0; }
            100% { background-position: 200px 200px, -150px 100px; }
        }

        /* الحاوية الرئيسية */
        .admin-container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 30px 20px;
            position: relative;
            z-index: 1;
        }

        /* الهيدر */
        .admin-header {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(18px);
            border-radius: 40px;
            padding: 30px;
            margin-bottom: 30px;
            border: 1px solid rgba(255,255,255,0.7);
            box-shadow: 0 20px 40px -20px rgba(0,80,120,0.2);
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 20px;
        }

        .admin-header h1 {
            font-size: 2rem;
            font-weight: 700;
            color: #0f172a;
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .admin-header h1 i {
            background: linear-gradient(145deg, #3b82f6, #8b5cf6);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .admin-stats {
            display: flex;
            gap: 20px;
        }

        .stat-box {
            background: white;
            border-radius: 24px;
            padding: 15px 25px;
            display: flex;
            flex-direction: column;
            align-items: center;
            border: 1px solid #e2e8f0;
            box-shadow: 0 10px 25px -12px rgba(0,0,0,0.1);
        }

        .stat-number {
            font-size: 2rem;
            font-weight: 700;
            color: #3b82f6;
            line-height: 1.2;
        }

        .stat-label {
            color: #64748b;
            font-size: 0.9rem;
        }

        /* الأقسام */
        .admin-section {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(18px);
            border-radius: 40px;
            padding: 30px;
            margin-bottom: 30px;
            border: 1px solid rgba(255,255,255,0.7);
            box-shadow: 0 20px 40px -20px rgba(0,80,120,0.2);
        }

        .admin-section h2 {
            font-size: 1.5rem;
            font-weight: 600;
            color: #0f172a;
            margin-bottom: 25px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .admin-section h2 i {
            background: linear-gradient(145deg, #3b82f6, #8b5cf6);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        /* رسائل التنبيه */
        .alert {
            padding: 16px 24px;
            border-radius: 20px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 12px;
            font-weight: 500;
            animation: slideDown 0.3s ease;
        }

        @keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .alert.success {
            background: #f0fdf4;
            border: 1px solid #86efac;
            color: #166534;
        }

        .alert.error {
            background: #fef2f2;
            border: 1px solid #fecaca;
            color: #991b1b;
        }

        .alert i {
            font-size: 1.2rem;
        }

        /* النموذج */
        .card-form {
            background: white;
            border-radius: 32px;
            padding: 30px;
            border: 1px solid #e2e8f0;
            box-shadow: 0 10px 25px -12px rgba(0,0,0,0.1);
        }

        .form-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
            margin-bottom: 25px;
        }

        .form-group {
            margin-bottom: 0;
        }

        .form-group.full-width {
            grid-column: 1 / -1;
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            color: #334155;
            font-weight: 600;
            font-size: 0.95rem;
        }

        .form-group input,
        .form-group textarea {
            width: 100%;
            padding: 14px 18px;
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 18px;
            font-size: 0.95rem;
            color: #0f172a;
            transition: all 0.3s ease;
            font-family: 'Plus Jakarta Sans', sans-serif;
        }

        .form-group input:focus,
        .form-group textarea:focus {
            outline: none;
            border-color: #3b82f6;
            background: white;
            box-shadow: 0 4px 12px rgba(59,130,246,0.1);
        }

        .form-group input[dir="ltr"] {
            text-align: left;
        }

        .btn-submit {
            background: linear-gradient(145deg, #3b82f6, #8b5cf6);
            color: white;
            border: none;
            padding: 16px 40px;
            border-radius: 40px;
            font-size: 1.1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 12px;
            box-shadow: 0 12px 28px -10px #3b82f6;
        }

        .btn-submit:hover {
            transform: translateY(-3px);
            box-shadow: 0 20px 35px -8px #3b82f6;
        }

        /* قائمة البطاقات */
        .cards-list {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
            gap: 20px;
        }

        .card-item {
            background: white;
            border-radius: 28px;
            padding: 25px;
            border: 1px solid #e2e8f0;
            transition: all 0.3s ease;
            box-shadow: 0 10px 25px -12px rgba(0,0,0,0.1);
        }

        .card-item:hover {
            transform: translateY(-5px);
            border-color: #a5b4fc;
            box-shadow: 0 20px 35px -18px #3b82f6;
        }

        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
            padding-bottom: 15px;
            border-bottom: 1px solid #e2e8f0;
        }

        .card-header h3 {
            color: #0f172a;
            font-size: 1.2rem;
            font-weight: 600;
        }

        .card-id {
            background: #eef2ff;
            color: #3b82f6;
            padding: 6px 15px;
            border-radius: 40px;
            font-size: 0.85rem;
            font-weight: 600;
        }

        .card-body {
            margin-bottom: 20px;
        }

        .card-body p {
            color: #64748b;
            margin-bottom: 8px;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 0.95rem;
        }

        .card-body i {
            color: #3b82f6;
            width: 20px;
        }

        .card-actions {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        .btn-view,
        .btn-edit,
        .btn-delete {
            padding: 10px 20px;
            border-radius: 40px;
            font-size: 0.9rem;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s ease;
            border: none;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .btn-view {
            background: #eef2ff;
            color: #3b82f6;
            border: 1px solid #a5b4fc;
        }

        .btn-edit {
            background: #f0f9ff;
            color: #0284c7;
            border: 1px solid #7dd3fc;
        }

        .btn-delete {
            background: #fef2f2;
            color: #dc2626;
            border: 1px solid #fecaca;
        }

        .btn-view:hover,
        .btn-edit:hover,
        .btn-delete:hover {
            transform: translateY(-2px);
            filter: brightness(0.95);
        }

        /* جدول الزيارات */
        .visits-table {
            overflow-x: auto;
            background: white;
            border-radius: 28px;
            border: 1px solid #e2e8f0;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        thead tr {
            background: #f8fafc;
            border-bottom: 2px solid #e2e8f0;
        }

        th {
            text-align: right;
            padding: 18px 20px;
            color: #334155;
            font-weight: 600;
            font-size: 0.95rem;
        }

        td {
            padding: 15px 20px;
            color: #64748b;
            border-bottom: 1px solid #e2e8f0;
        }

        tr:last-child td {
            border-bottom: none;
        }

        tr:hover td {
            background: #f8fafc;
        }

        /* قسم التحكم Lava Lamp */
        .lava-control {
            background: white;
            border-radius: 28px;
            padding: 25px;
            border: 1px solid #e2e8f0;
            margin-bottom: 20px;
        }

        .lava-header {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 20px;
        }

        .lava-header i {
            font-size: 1.5rem;
            color: #3b82f6;
        }

        .lava-header h5 {
            font-size: 1.2rem;
            color: #0f172a;
        }

        .form-check {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 15px;
        }

        .form-check-input {
            width: 50px;
            height: 26px;
            appearance: none;
            background: #cbd5e1;
            border-radius: 30px;
            position: relative;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .form-check-input:checked {
            background: linear-gradient(145deg, #3b82f6, #8b5cf6);
        }

        .form-check-input::before {
            content: '';
            position: absolute;
            width: 22px;
            height: 22px;
            background: white;
            border-radius: 50%;
            top: 2px;
            right: 2px;
            transition: all 0.3s ease;
        }

        .form-check-input:checked::before {
            right: calc(100% - 24px);
        }

        .form-check-label {
            color: #334155;
            font-weight: 500;
        }

        .form-select {
            width: 100%;
            padding: 12px 18px;
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 18px;
            color: #0f172a;
            font-family: 'Plus Jakarta Sans', sans-serif;
            cursor: pointer;
        }

        .btn-primary {
            background: linear-gradient(145deg, #3b82f6, #8b5cf6);
            color: white;
            border: none;
            padding: 12px 30px;
            border-radius: 40px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px -8px #3b82f6;
        }

        /* تصميم متجاوب */
        @media (max-width: 768px) {
            .admin-header {
                flex-direction: column;
                text-align: center;
            }

            .admin-stats {
                width: 100%;
                justify-content: center;
            }

            .cards-list {
                grid-template-columns: 1fr;
            }

            .form-grid {
                grid-template-columns: 1fr;
            }

            .card-actions {
                flex-direction: column;
            }

            .btn-view,
            .btn-edit,
            .btn-delete {
                width: 100%;
                justify-content: center;
            }
        }

        /* تخصيص شريط التمرير */
        ::-webkit-scrollbar {
            width: 10px;
        }

        ::-webkit-scrollbar-track {
            background: #e2e8f0;
        }

        ::-webkit-scrollbar-thumb {
            background: linear-gradient(145deg, #a5b4fc, #bae6fd);
            border-radius: 10px;
        }
    </style>
</head>
<body>
    <div class="background">
        <div class="gradient-orb"></div>
        <div class="gradient-orb-2"></div>
        <div class="particles"></div>
    </div>

    <div class="admin-container">
        <header class="admin-header">
            <h1>
                <i class="fas fa-cogs"></i>
                لوحة التحكم - بطاقات NFC
            </h1>
            <div class="admin-stats">
                <div class="stat-box">
                <span class="stat-number"><%= profiles ? profiles.length : 0 %></span>
                <span class="stat-label">إجمالي البطاقات NFC</span>
                </div>
                <div class="stat-box">
                    <span class="stat-number"><%= visits ? visits.length : 0 %></span>
                    <span class="stat-label">إجمالي الزيارات</span>
                </div>
            </div>
        </header>

        <!-- رسائل النجاح والخطأ -->
        <% if (query && query.success) { %>
        <div class="alert success"><i class="fas fa-check-circle"></i> <%= query.success %></div>
        <% } %>
        <% if (query && query.error) { %>
        <div class="alert error"><i class="fas fa-exclamation-circle"></i> <%= query.error %></div>
        <% } %>

        <!-- نموذج إضافة بطاقة جديدة -->
        <div class="admin-section">
            <h2><i class="fas fa-plus-circle"></i> إضافة بطاقة جديدة</h2>
            <form action="/admin/card/add" method="POST" class="card-form">
                <div class="form-grid">
                    <div class="form-group">
                        <label>معرف البطاقة (NFC ID):</label>
                        <input type="text" name="cardId" placeholder="nfc-001" required>
                    </div>
                    <div class="form-group">
                        <label>الاسم الكامل:</label>
                        <input type="text" name="name" required>
                    </div>
                    <div class="form-group">
                        <label>المسمى الوظيفي:</label>
                        <input type="text" name="title" required>
                    </div>
                    <div class="form-group">
                        <label>الشركة:</label>
                        <input type="text" name="company">
                    </div>
                    <div class="form-group">
                        <label>البريد الإلكتروني:</label>
                        <input type="email" name="email">
                    </div>
                    <div class="form-group">
                        <label>رقم الجوال:</label>
                        <input type="tel" name="phone" dir="ltr">
                    </div>
                    <div class="form-group">
                        <label>الموقع الإلكتروني:</label>
                        <input type="url" name="website" dir="ltr">
                    </div>
                    <div class="form-group">
                        <label>العنوان:</label>
                        <input type="text" name="address">
                    </div>
                    <div class="form-group full-width">
                        <label>نبذة تعريفية:</label>
                        <textarea name="bio" rows="3"></textarea>
                    </div>
                    <div class="form-group">
                        <label>LinkedIn:</label>
                        <input type="url" name="linkedin" dir="ltr">
                    </div>
                    <div class="form-group">
                        <label>Twitter/X:</label>
                        <input type="url" name="twitter" dir="ltr">
                    </div>
                    <div class="form-group">
                        <label>GitHub:</label>
                        <input type="url" name="github" dir="ltr">
                    </div>
                    <div class="form-group full-width">
                        <label>رابط ديناميكي:</label>
                        <input type="url" name="dynamicLink" dir="ltr" placeholder="https://...">
                    </div>
                </div>
                <button type="submit" class="btn-submit">
                    <i class="fas fa-save"></i>
                    إضافة البطاقة
                </button>
            </form>
        </div>

        <!-- قائمة البطاقات الموجودة -->
        <div class="admin-section">
            <h2><i class="fas fa-list"></i> البطاقات الموجودة</h2>
            <div class="cards-list">
                <% if (profiles && profiles.length > 0) { %>
                    <% profiles.forEach(card => { %>
                    <div class="card-item">
                        <div class="card-header">
                            <h3><%= card.name %></h3>
                            <span class="card-id"><%= card.cardId || card.profileId %></span>
                        </div>
                        <div class="card-body">
                            <p><i class="fas fa-briefcase"></i> <%= card.title || '' %> <%= card.company ? '- ' + card.company : '' %></p>
                            <p><i class="fas fa-phone"></i> <%= card.phone || 'غير متوفر' %></p>
                            <p><i class="fas fa-envelope"></i> <%= card.email || 'غير متوفر' %></p>
                        </div>
                        <div class="card-actions">
                            <a href="/card/<%= card.cardId %>" target="_blank" class="btn-view">
                                <i class="fas fa-eye"></i> عرض
                            </a>
                            <a href="/admin/card/edit/<%= card.cardId || card.profileId %>" class="btn-edit">
                                <i class="fas fa-edit"></i> تعديل
                            </a>
                            <form action="/admin/card/delete/<%= card.cardId %>" method="POST" style="display:inline;" 
                                  onsubmit="return confirm('هل أنت متأكد من حذف هذه البطاقة؟')">
                                <button type="submit" class="btn-delete">
                                    <i class="fas fa-trash"></i> حذف
                                </button>
                            </form>
                        </div>
                    </div>
                    <% }) %>
                <% } else { %>
                    <p style="color: #64748b; text-align: center; padding: 40px;">لا توجد بطاقات مضافة بعد</p>
                <% } %>
            </div>
        </div>

        <!-- سجل الزيارات -->
        <div class="admin-section">
            <h2><i class="fas fa-chart-line"></i> سجل الزيارات</h2>
            <div class="visits-table">
                <table>
                    <thead>
                        <tr>
                            <th>البطاقة</th>
                            <th>التاريخ والوقت</th>
                            <th>IP العنوان</th>
                            <th>المتصفح</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (visits && visits.length > 0) { %>
                            <% visits.slice(0, 20).forEach(visit => { %>
                            <tr>
                                <td><%= visit.cardId %></td>
                                <td><%= new Date(visit.timestamp).toLocaleString('ar-SA') %></td>
                                <td><%= visit.ip %></td>
                                <td><%= visit.userAgent ? visit.userAgent.substring(0, 50) + '...' : 'غير معروف' %></td>
                            </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="4" style="text-align: center; color: #64748b;">لا توجد زيارات بعد</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- قسم التحكم في Lava Lamp -->
        <div class="admin-section">
            <h2><i class="fas fa-palette"></i> التحكم في تأثير Lava Lamp</h2>
            <div class="lava-control">
                <div class="lava-header">
                    <i class="fas fa-fire"></i>
                    <h5>إعدادات التأثير</h5>
                </div>
                <div class="row">
                    <div class="form-check">
                        <input type="checkbox" class="form-check-input" id="lavaLampToggle" 
                               <%= enableLavaLamp ? 'checked' : '' %>>
                        <label class="form-check-label" for="lavaLampToggle">
                            تفعيل تأثير Lava Lamp
                        </label>
                    </div>
                    <div style="margin-bottom: 15px;">
                        <select class="form-select" id="lavaIntensity">
                            <option value="low">منخفض</option>
                            <option value="medium" selected>متوسط</option>
                            <option value="high">عالي</option>
                        </select>
                    </div>
                </div>
                <button class="btn-primary" onclick="saveLavaSettings()">
                    <i class="fas fa-save"></i>
                    حفظ الإعدادات
                </button>
            </div>
        </div>
    </div>

    <script>
        // دالة تعديل البطاقة
        function editCard(cardId) {
            window.location.href = `/admin/card/edit/${cardId}`;
        }

        // حفظ إعدادات Lava Lamp
        function saveLavaSettings() {
            const enabled = document.getElementById('lavaLampToggle').checked;
            const intensity = document.getElementById('lavaIntensity').value;
            
            fetch('/api/lava-lamp/settings', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ 
                    enabled, 
                    intensity, 
                    interactive: true, 
                    autoColor: true 
                })
            })
            .then(res => res.json())
            .then(data => {
                alert('تم حفظ الإعدادات بنجاح');
                if (enabled) {
                    location.reload();
                }
            })
            .catch(error => {
                alert('حدث خطأ في حفظ الإعدادات');
            });
        }

        // تحديث الإحصائيات كل 30 ثانية
        setInterval(() => {
            location.reload();
        }, 30000);

        // تأثيرات تفاعلية
        document.addEventListener('DOMContentLoaded', function() {
            // إضافة تأثير hover للحقول
            const inputs = document.querySelectorAll('input, textarea, select');
            inputs.forEach(input => {
                input.addEventListener('focus', function() {
                    this.style.transform = 'scale(1.01)';
                });
                input.addEventListener('blur', function() {
                    this.style.transform = 'scale(1)';
                });
            });
        });
    </script>
</body>
</html>
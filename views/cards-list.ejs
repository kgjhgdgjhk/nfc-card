ف<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'جميع البطاقات المتاحة' %> | NFC Pro</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: #f4f9fe;
            color: #1e293b;
            min-height: 100vh;
            position: relative;
        }

        /* خلفية متحركة فاتحة */
        .background {
            position: fixed;
            width: 100vw;
            height: 100vh;
            top: 0;
            left: 0;
            z-index: -1;
            overflow: hidden;
        }

        .gradient-orb {
            position: absolute;
            width: 80vmax;
            height: 80vmax;
            background: radial-gradient(circle at 30% 50%, rgba(147, 197, 253, 0.5) 0%, rgba(165, 180, 252, 0.4) 50%, transparent 70%);
            border-radius: 50%;
            top: -20%;
            right: -20%;
            animation: floatOrb 30s ease-in-out infinite;
        }

        .gradient-orb-2 {
            position: absolute;
            width: 70vmax;
            height: 70vmax;
            background: radial-gradient(circle at 70% 50%, rgba(216, 180, 254, 0.4) 0%, rgba(187, 222, 252, 0.4) 50%, transparent 70%);
            border-radius: 50%;
            bottom: -20%;
            left: -20%;
            animation: floatOrb 35s ease-in-out infinite reverse;
        }

        @keyframes floatOrb {
            0%, 100% { transform: translate(0, 0) scale(1); }
            50% { transform: translate(-5%, 5%) scale(1.05); }
        }

        .particles {
            position: absolute;
            width: 100%;
            height: 100%;
            background-image: 
                radial-gradient(circle at 20% 30%, rgba(59, 130, 246, 0.06) 1.5px, transparent 1.5px),
                radial-gradient(circle at 80% 70%, rgba(139, 92, 246, 0.05) 1px, transparent 1px);
            background-size: 130px 130px;
            animation: moveParticles 50s linear infinite;
            opacity: 0.4;
        }

        @keyframes moveParticles {
            0% { background-position: 0 0, 0 0; }
            100% { background-position: 200px 200px, -150px 100px; }
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 30px 20px;
            position: relative;
            z-index: 1;
        }

        /* الهيدر */
        .header {
            margin-bottom: 40px;
            position: relative;
        }

        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: #3b82f6;
            text-decoration: none;
            font-weight: 500;
            background: white;
            padding: 12px 25px;
            border-radius: 40px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
            border: 1px solid #e2e8f0;
            transition: all 0.3s ease;
            margin-bottom: 20px;
        }

        .back-link:hover {
            transform: translateX(-5px);
            border-color: #3b82f6;
            box-shadow: 0 10px 25px -10px #3b82f6;
        }

        .back-link i {
            font-size: 0.9rem;
        }

        h1 {
            color: #0f172a;
            font-size: 2.5rem;
            font-weight: 700;
            text-align: center;
            margin-bottom: 15px;
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 15px;
        }

        h1 i {
            background: linear-gradient(145deg, #3b82f6, #8b5cf6);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-size: 2.2rem;
        }

        .subtitle {
            text-align: center;
            color: #64748b;
            font-size: 1.1rem;
            max-width: 600px;
            margin: 0 auto 30px;
        }

        /* إحصائيات سريعة */
        .stats-bar {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-bottom: 40px;
            flex-wrap: wrap;
        }

        .stat-chip {
            background: white;
            border: 1px solid #e2e8f0;
            border-radius: 40px;
            padding: 12px 25px;
            display: flex;
            align-items: center;
            gap: 10px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.02);
        }

        .stat-chip i {
            color: #3b82f6;
            font-size: 1.1rem;
        }

        .stat-chip span {
            color: #0f172a;
            font-weight: 600;
        }

        .stat-chip small {
            color: #64748b;
            font-weight: normal;
        }

        /* شبكة البطاقات */
        .cards-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 25px;
            margin-top: 20px;
        }

        .card-item {
            background: white;
            border-radius: 28px;
            padding: 25px;
            border: 1px solid #e2e8f0;
            transition: all 0.3s ease;
            box-shadow: 0 10px 25px -12px rgba(0,0,0,0.1);
            position: relative;
            overflow: hidden;
        }

        .card-item:hover {
            transform: translateY(-5px);
            border-color: #a5b4fc;
            box-shadow: 0 20px 35px -18px #3b82f6;
        }

        .card-badge {
            position: absolute;
            top: 20px;
            left: 20px;
            background: linear-gradient(145deg, #3b82f6, #8b5cf6);
            color: white;
            padding: 5px 12px;
            border-radius: 40px;
            font-size: 0.75rem;
            font-weight: 600;
            box-shadow: 0 4px 10px -5px #3b82f6;
        }

        .card-name {
            font-size: 1.5rem;
            font-weight: 700;
            color: #0f172a;
            margin-bottom: 15px;
            padding-left: 60px;
            border-bottom: 2px solid #e2e8f0;
            padding-bottom: 15px;
        }

        .card-details {
            margin: 20px 0;
        }

        .card-detail {
            display: flex;
            align-items: center;
            gap: 10px;
            margin: 12px 0;
            color: #64748b;
            font-size: 0.95rem;
        }

        .card-detail i {
            width: 20px;
            color: #3b82f6;
            font-size: 1rem;
        }

        .card-detail strong {
            color: #334155;
            font-weight: 600;
            min-width: 70px;
        }

        .card-detail span {
            flex: 1;
            word-break: break-word;
        }

        .card-stats {
            display: flex;
            gap: 15px;
            margin: 20px 0;
            padding: 15px 0;
            border-top: 1px solid #e2e8f0;
            border-bottom: 1px solid #e2e8f0;
        }

        .stat-item {
            flex: 1;
            text-align: center;
        }

        .stat-value {
            font-size: 1.2rem;
            font-weight: 700;
            color: #3b82f6;
        }

        .stat-label {
            font-size: 0.8rem;
            color: #64748b;
        }

        .card-link {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            width: 100%;
            padding: 14px;
            background: linear-gradient(145deg, #3b82f6, #8b5cf6);
            color: white;
            text-decoration: none;
            border-radius: 40px;
            font-weight: 600;
            font-size: 1rem;
            transition: all 0.3s ease;
            border: none;
            cursor: pointer;
        }

        .card-link:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px -5px #3b82f6;
        }

        .card-link i {
            font-size: 0.9rem;
        }

        /* حالة عدم وجود بطاقات */
        .no-cards {
            grid-column: 1 / -1;
            text-align: center;
            padding: 60px 20px;
            background: white;
            border-radius: 40px;
            border: 1px solid #e2e8f0;
            box-shadow: 0 10px 25px -12px rgba(0,0,0,0.1);
        }

        .no-cards i {
            font-size: 4rem;
            color: #cbd5e1;
            margin-bottom: 20px;
        }

        .no-cards p {
            color: #64748b;
            font-size: 1.2rem;
            margin-bottom: 20px;
        }

        .btn-create {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 14px 30px;
            background: linear-gradient(145deg, #3b82f6, #8b5cf6);
            color: white;
            text-decoration: none;
            border-radius: 40px;
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .btn-create:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px -5px #3b82f6;
        }

        /* تذييل */
        .footer {
            text-align: center;
            margin-top: 50px;
            color: #94a3b8;
            font-size: 0.9rem;
        }

        /* تصميم متجاوب */
        @media (max-width: 768px) {
            h1 {
                font-size: 2rem;
            }
            
            h1 i {
                font-size: 1.8rem;
            }
            
            .cards-grid {
                grid-template-columns: 1fr;
            }
            
            .stats-bar {
                flex-direction: column;
                align-items: center;
            }
            
            .stat-chip {
                width: 100%;
                justify-content: center;
            }
            
            .card-name {
                font-size: 1.3rem;
            }
        }

        /* تخصيص شريط التمرير */
        ::-webkit-scrollbar {
            width: 10px;
        }

        ::-webkit-scrollbar-track {
            background: #e2e8f0;
        }

        ::-webkit-scrollbar-thumb {
            background: linear-gradient(145deg, #a5b4fc, #bae6fd);
            border-radius: 10px;
        }

        /* تأثيرات إضافية */
        .pulse {
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.7; }
        }

        .protected-badge {
            display: inline-block;
            padding: 3px 10px;
            background: #fef2f2;
            color: #dc2626;
            border-radius: 40px;
            font-size: 0.7rem;
            font-weight: 600;
            margin-right: 10px;
        }
    </style>
</head>
<body>
    <div class="background">
        <div class="gradient-orb"></div>
        <div class="gradient-orb-2"></div>
        <div class="particles"></div>
    </div>

    <div class="container">
        <div class="header">
            <a href="/" class="back-link">
                <i class="fas fa-arrow-right"></i>
                العودة للرئيسية
            </a>
            
            <h1>
                <i class="fas fa-id-card"></i>
                البطاقات المتاحة
            </h1>
            <p class="subtitle">
                تصفح جميع البطاقات الذكية المتاحة في النظام
            </p>

            <% if (profiles && profiles.length > 0) { %>
            <div class="stats-bar">
                <div class="stat-chip">
                    <i class="fas fa-id-card"></i>
                    <span><%= profiles.length %></span>
                    <small>بطاقة متاحة</small>
                </div>
                <div class="stat-chip">
                    <i class="fas fa-eye"></i>
                    <span><%= profiles.reduce((sum, p) => sum + (p.stats?.views || 0), 0) %></span>
                    <small>إجمالي المشاهدات</small>
                </div>
                <div class="stat-chip">
                    <i class="fas fa-shield-alt"></i>
                    <span><%= profiles.filter(p => p.isPasswordProtected).length %></span>
                    <small>بطاقة محمية</small>
                </div>
            </div>
            <% } %>
        </div>

        <div class="cards-grid">
            <% if (profiles && profiles.length > 0) { %>
                <% profiles.forEach(profile => { 
                    const profileId = profile.profileId || profile.cardId;
                    const views = profile.stats?.views || 0;
                    const isProtected = profile.isPasswordProtected && profile.password;
                %>
                    <div class="card-item">
                        <% if (isProtected) { %>
                            <div class="card-badge">
                                <i class="fas fa-lock"></i> محمي
                            </div>
                        <% } %>
                        
                        <div class="card-name">
                            <%= profile.name || 'بدون اسم' %>
                        </div>

                        <div class="card-details">
                            <% if (profile.email) { %>
                            <div class="card-detail">
                                <i class="fas fa-envelope"></i>
                                <strong>البريد:</strong>
                                <span><%= profile.email %></span>
                            </div>
                            <% } %>

                            <% if (profile.phone) { %>
                            <div class="card-detail">
                                <i class="fas fa-phone"></i>
                                <strong>الهاتف:</strong>
                                <span dir="ltr"><%= profile.phone %></span>
                            </div>
                            <% } %>

<div class="card-detail">
    <i class="fas fa-briefcase"></i>
    <strong>المسمى:</strong>
    <span><%= profile.title || 'غير محدد' %></span>
</div>

                            <% if (profile.company) { %>
                            <div class="card-detail">
                                <i class="fas fa-building"></i>
                                <strong>الشركة:</strong>
                                <span><%= profile.company %></span>
                            </div>
                            <% } %>

                            <% if (profile.website) { %>
                            <div class="card-detail">
                                <i class="fas fa-globe"></i>
                                <strong>الموقع:</strong>
                                <a href="<%= profile.website %>" target="_blank" style="color: #3b82f6; text-decoration: none;"><%= new URL(profile.website).hostname %></a>
                            </div>
                            <% } %>

                            <% if (profile.bio) { %>
                            <div class="card-detail">
                                <i class="fas fa-pen"></i>
                                <strong>نبذة:</strong>
                                <span><%= profile.bio.substring(0, 50) %><%= profile.bio.length > 50 ? '...' : '' %></span>
                            </div>
                            <% } %>
                        </div>

                        <div class="card-stats">
                            <div class="stat-item">
                                <div class="stat-value"><%= views %></div>
                                <div class="stat-label">مشاهدة</div>
                            </div>
                            <div class="stat-item">
                                <div class="stat-value"><%= profile.template || 'modern' %></div>
                                <div class="stat-label">قالب</div>
                            </div>
                            <div class="stat-item">
                                <div class="stat-value"><%= new Date(profile.createdAt).toLocaleDateString('ar-SA') %></div>
                                <div class="stat-label">تاريخ</div>
                            </div>
                        </div>

                        <a href="/p/<%= profileId %>" class="card-link" target="_blank">
                            <i class="fas fa-eye"></i>
                            عرض البطاقة
                            <i class="fas fa-external-link-alt"></i>
                        </a>
                    </div>
                <% }); %>
            <% } else { %>
                <div class="no-cards">
                    <i class="fas fa-id-card"></i>
                    <p>لا توجد بطاقات متاحة حالياً</p>
                    <a href="/create-profile" class="btn-create">
                        <i class="fas fa-plus-circle"></i>
                        إنشاء أول بطاقة
                    </a>
                </div>
            <% } %>
        </div>

        <% if (profiles && profiles.length > 0) { %>
        
        <% } %>
    </div>
</body>
</html>
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        
        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }
        
        .container {
            max-width: 1200px;
            margin: 0 auto;
        }
        
        h1 {
            color: white;
            text-align: center;
            margin: 30px 0;
            font-size: 2.5em;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
        }
        
        .cards-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 20px;
            margin-top: 20px;
        }
        
        .card-item {
            background: white;
            border-radius: 15px;
            padding: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            transition: transform 0.3s ease;
        }
        
        .card-item:hover {
            transform: translateY(-5px);
        }
        
        .card-name {
            font-size: 1.5em;
            color: #333;
            margin-bottom: 10px;
            border-bottom: 2px solid #667eea;
            padding-bottom: 10px;
        }
        
        .card-detail {
            margin: 10px 0;
            color: #666;
        }
        
        .card-detail strong {
            color: #333;
            width: 80px;
            display: inline-block;
        }
        
        .card-link {
            display: inline-block;
            margin-top: 15px;
            padding: 10px 20px;
            background: #667eea;
            color: white;
            text-decoration: none;
            border-radius: 8px;
            transition: background 0.3s ease;
        }
        
        .card-link:hover {
            background: #5a67d8;
        }
        
        .no-cards {
            text-align: center;
            color: white;
            font-size: 1.2em;
            grid-column: 1 / -1;
            padding: 50px;
        }
        
        .back-link {
            display: inline-block;
            margin-bottom: 20px;
            color: white;
            text-decoration: none;
            font-size: 1.1em;
        }
        
        .back-link:hover {
            text-decoration: underline;
        }
    </style>
</head>
<body>
    <div class="container">
        <a href="/" class="back-link">← العودة للرئيسية</a>
        <h1>البطاقات المتاحة</h1>
        
        <div class="cards-grid">
            <% if (profiles && profiles.length > 0) { %>
                <% profiles.forEach(profile => { %>
                    <div class="card-item">
                        <div class="card-name"><%= profile.name || 'بدون اسم' %></div>
                        <div class="card-detail">
                            <strong>البريد:</strong> <%= profile.email || 'غير محدد' %>
                        </div>
                        <div class="card-detail">
                            <strong>الهاتف:</strong> <%= profile.phone || 'غير محدد' %>
                        </div>
                        <% if (profile.title) { %>
                        <div class="card-detail">
                            <strong>المسمى:</strong> <%= profile.title %>
                        </div>
                        <% } %>
                        <% if (profile.company) { %>
                        <div class="card-detail">
                            <strong>الشركة:</strong> <%= profile.company %>
                        </div>
                        <% } %>
                        <div class="card-detail">
                            <strong>المشاهدات:</strong> <%= profile.stats?.views || 0 %>
                        </div>
                        <a href="/p/<%= profile.profileId || profile.cardId %>" class="card-link">عرض البطاقة</a>
                    </div>
                <% }); %>
            <% } else { %>
                <div class="no-cards">
                    <p>لا توجد بطاقات متاحة حالياً</p>
                    <a href="/create-profile" style="color: white; display: block; margin-top: 20px;">إنشاء أول بطاقة</a>
                </div>
            <% } %>
        </div>
    </div>
</body>
</html>
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NFC Pro | اختر قالب بطاقتك • 10 قوالب</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: #f4f9fe;
            min-height: 100vh;
            position: relative;
            overflow-x: hidden;
            color: #1e293b;
        }
        /* نفس الخلفية السابقة */
        .background {
            position: fixed;
            width: 100vw;
            height: 100vh;
            top: 0;
            left: 0;
            z-index: -1;
            overflow: hidden;
        }
        .gradient-orb {
            position: absolute;
            width: 80vmax;
            height: 80vmax;
            background: radial-gradient(circle at 30% 50%, rgba(147, 197, 253, 0.5) 0%, rgba(165, 180, 252, 0.4) 50%, transparent 70%);
            border-radius: 50%;
            top: -20%;
            right: -20%;
            animation: floatOrb 30s ease-in-out infinite;
        }
        .gradient-orb-2 {
            position: absolute;
            width: 70vmax;
            height: 70vmax;
            background: radial-gradient(circle at 70% 50%, rgba(216, 180, 254, 0.4) 0%, rgba(187, 222, 252, 0.4) 50%, transparent 70%);
            border-radius: 50%;
            bottom: -20%;
            left: -20%;
            animation: floatOrb 35s ease-in-out infinite reverse;
        }
        @keyframes floatOrb {
            0%, 100% { transform: translate(0, 0) scale(1); }
            50% { transform: translate(-5%, 5%) scale(1.05); }
        }
        .particles {
            position: absolute;
            width: 100%;
            height: 100%;
            background-image: radial-gradient(circle at 20% 30%, rgba(59, 130, 246, 0.08) 1.5px, transparent 1.5px), radial-gradient(circle at 80% 70%, rgba(139, 92, 246, 0.06) 1px, transparent 1px);
            background-size: 130px 130px;
            animation: moveParticles 50s linear infinite;
            opacity: 0.5;
        }
        @keyframes moveParticles {
            0% { background-position: 0 0, 0 0; }
            100% { background-position: 200px 200px, -150px 100px; }
        }

        .profile-creation {
            min-height: 100vh;
            padding: 40px 20px;
            position: relative;
            z-index: 1;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .creation-container {
            max-width: 1400px;
            width: 100%;
            margin: 0 auto;
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(18px);
            border-radius: 48px;
            overflow: hidden;
            box-shadow: 0 30px 60px -20px rgba(0, 80, 120, 0.2), 0 0 0 1px rgba(255, 255, 255, 0.8) inset;
            border: 1px solid rgba(255,255,255,0.7);
            animation: slideUp 0.8s cubic-bezier(0.2,0.9,0.3,1);
        }
        @keyframes slideUp {
            from { opacity: 0; transform: translateY(40px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .steps-header {
            padding: 30px 40px;
            border-bottom: 1px solid rgba(0,0,0,0.05);
            background: rgba(255,255,255,0.3);
        }
        .steps-progress {
            display: flex;
            justify-content: space-between;
            position: relative;
            margin-bottom: 10px;
        }
        .steps-progress::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 60px;
            right: 60px;
            height: 2px;
            background: linear-gradient(90deg, transparent, rgba(0,0,0,0.1), transparent);
            transform: translateY(-50%);
            z-index: 1;
        }
        .step-item {
            position: relative;
            z-index: 2;
            background: white;
            backdrop-filter: blur(10px);
            padding: 12px 28px;
            border-radius: 100px;
            display: flex;
            align-items: center;
            gap: 12px;
            color: #64748b;
            border: 1px solid rgba(0,0,0,0.05);
            transition: all 0.3s ease;
            cursor: pointer;
            box-shadow: 0 4px 10px rgba(0,0,0,0.02);
            font-weight: 500;
        }
        .step-item.completed {
            background: #f0fdf4;
            border-color: #86efac;
            color: #166534;
        }
        .step-item.active {
            background: linear-gradient(145deg, #ffffff, #f0f9ff);
            border-color: #3b82f6;
            color: #1e293b;
            box-shadow: 0 10px 25px -8px #90caf9;
            animation: pulse 2s infinite;
        }
        @keyframes pulse {
            0% { box-shadow: 0 0 0 0 rgba(59, 130, 246, 0.3); }
            70% { box-shadow: 0 0 0 12px rgba(59, 130, 246, 0); }
            100% { box-shadow: 0 0 0 0 rgba(59, 130, 246, 0); }
        }
        .step-number {
            width: 32px;
            height: 32px;
            background: #e2e8f0;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            font-size: 0.9rem;
            transition: all 0.3s ease;
            color: #334155;
        }
        .active .step-number, .completed .step-number {
            background: linear-gradient(145deg, #3b82f6, #8b5cf6);
            color: white;
        }

        .form-section {
            padding: 50px 40px;
        }
        .form-section h2 {
            color: #0f172a;
            margin-bottom: 40px;
            font-size: 2.2rem;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 15px;
        }
        .form-section h2 i {
            background: linear-gradient(145deg, #2563eb, #a78bfa);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            animation: rotate 3s linear infinite;
        }
        @keyframes rotate {
            0% { transform: rotate(0deg); }
            25% { transform: rotate(5deg); }
            75% { transform: rotate(-5deg); }
            100% { transform: rotate(0deg); }
        }

        /* شبكة القوالب - 10 قوالب */
        .templates-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 25px;
            margin: 30px 0;
        }
        .template-card {
            background: rgba(255, 255, 255, 0.8);
            border: 1px solid #e2e8f0;
            border-radius: 24px;
            overflow: hidden;
            cursor: pointer;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            opacity: 0;
            transform: translateY(30px);
            animation: cardAppear 0.6s ease-out forwards;
            box-shadow: 0 10px 25px -12px rgba(0,0,0,0.1);
        }
        .template-card:nth-child(1) { animation-delay: 0.1s; }
        .template-card:nth-child(2) { animation-delay: 0.2s; }
        .template-card:nth-child(3) { animation-delay: 0.3s; }
        .template-card:nth-child(4) { animation-delay: 0.4s; }
        .template-card:nth-child(5) { animation-delay: 0.5s; }
        .template-card:nth-child(6) { animation-delay: 0.6s; }
        .template-card:nth-child(7) { animation-delay: 0.7s; }
        .template-card:nth-child(8) { animation-delay: 0.8s; }
        .template-card:nth-child(9) { animation-delay: 0.9s; }
        .template-card:nth-child(10) { animation-delay: 1s; }

        @keyframes cardAppear {
            to { opacity: 1; transform: translateY(0); }
        }
        .template-card:hover {
            transform: translateY(-6px) scale(1.02);
            border-color: #3b82f6;
            box-shadow: 0 20px 30px -15px #3b82f6, 0 0 0 1px #a5b4fc inset;
        }
        .template-card.selected {
            border-color: #3b82f6;
            background: linear-gradient(145deg, #ffffff, #f0f9ff);
            box-shadow: 0 20px 40px -10px #3b82f6;
        }
        .template-preview {
            height: 160px;
            position: relative;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: bold;
        }
        .template-info {
            padding: 20px;
            border-top: 1px solid #e2e8f0;
        }
        .template-info h3 {
            color: #0f172a;
            margin-bottom: 5px;
            font-size: 1.2rem;
        }
        .template-info p {
            color: #64748b;
            font-size: 0.9rem;
            margin-bottom: 10px;
        }
        .template-badge {
            display: inline-block;
            padding: 4px 12px;
            background: linear-gradient(145deg, #3b82f6, #8b5cf6);
            color: white;
            border-radius: 100px;
            font-size: 0.75rem;
            font-weight: 600;
        }
        .selected-icon {
            position: absolute;
            top: 10px;
            left: 10px;
            width: 30px;
            height: 30px;
            background: linear-gradient(145deg, #3b82f6, #8b5cf6);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 1rem;
            opacity: 0;
            transform: scale(0) rotate(-180deg);
            transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
            z-index: 10;
        }
        .template-card.selected .selected-icon {
            opacity: 1;
            transform: scale(1) rotate(0);
        }
        .radio-input { display: none; }

        .form-navigation {
            display: flex;
            justify-content: space-between;
            margin-top: 50px;
            padding-top: 30px;
            border-top: 1px solid rgba(0,0,0,0.05);
        }
        .btn-next, .btn-prev {
            padding: 14px 42px;
            border-radius: 40px;
            font-size: 1.1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.25s ease;
            display: flex;
            align-items: center;
            gap: 12px;
            border: none;
            text-decoration: none;
        }
        .btn-next {
            background: linear-gradient(145deg, #3b82f6, #8b5cf6);
            color: white;
            box-shadow: 0 12px 28px -10px #3b82f6;
        }
        .btn-prev {
            background: white;
            color: #334155;
            border: 1px solid #e2e8f0;
        }
        .btn-next:hover { transform: translateY(-3px); box-shadow: 0 20px 35px -8px #3b82f6; }
        .btn-prev:hover { background: #f8fafc; border-color: #cbd5e1; transform: translateY(-2px); }
        .btn-next i, .btn-prev i { font-size: 1.2rem; transition: transform 0.3s ease; }
        .btn-next:hover i:last-child { transform: translateX(-6px); }
        .btn-prev:hover i:first-child { transform: translateX(6px); }

        .hint {
            font-size: 0.95rem;
            color: #64748b;
            margin-top: 20px;
            display: flex;
            align-items: center;
            gap: 8px;
            justify-content: center;
        }

        @media (max-width: 768px) {
            .templates-grid { grid-template-columns: 1fr; }
            .steps-progress { flex-direction: column; gap: 12px; }
            .steps-progress::before { display: none; }
            .step-item { width: 100%; }
            .form-section { padding: 30px 20px; }
        }

        /* تصاميم المعاينة للقوالب */
        .preview-modern { background: linear-gradient(135deg, #667eea, #764ba2); width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: white; }
        .preview-classic { background: linear-gradient(145deg, #2d3748, #1e293b); width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: #e2e8f0; }
        .preview-minimal { background: white; width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: #1e293b; border: 1px solid #e2e8f0; }
        .preview-dark { background: #0f172a; width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: white; }
        .preview-tech { background: linear-gradient(145deg, #0f2027, #203a43, #2c5364); width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: #e0f2fe; }
        .preview-elegant { background: linear-gradient(145deg, #42275a, #734b6d); width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: #f8f0fc; }
        .preview-corporate { background: #1e3c72; width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: white; background: linear-gradient(145deg, #1e3c72, #2a5298); }
        .preview-creative { background: linear-gradient(145deg, #f12711, #f5af19); width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: white; }
        .preview-3d { background: linear-gradient(145deg, #0b0c10, #1f2833, #0b0c10); width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: #66fcf1; }
        .preview-neon { background: linear-gradient(145deg, #0f0c29, #302b63, #24243e); width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: #fff; text-shadow: 0 0 10px cyan; }
    </style>
</head>
<body>
    <div class="background">
        <div class="gradient-orb"></div>
        <div class="gradient-orb-2"></div>
        <div class="particles"></div>
    </div>

    <div class="profile-creation">
        <div class="creation-container">
            <div class="steps-header">
                <div class="steps-progress">
                    <div class="step-item completed">
                        <span class="step-number">1</span>
                        <span>الخطوة الاولى </span>
                        <i class="fas fa-check"></i>
                    </div>
                    <div class="step-item active">
                        <span class="step-number">2</span>
                        <span>الخطوة الثانية </span>
                        <i class="fas fa-palette"></i>
                    </div>
                    <div class="step-item">
                        <span class="step-number">3</span>
                        <span>الخطوة الثالثة </span>
                    </div>
                    <div class="step-item">
                        <span class="step-number">4</span>
                        <span>التأكيد</span>
                    </div>
                </div>
            </div>
            
            <div class="form-section">
                <h2>
                    <i class="fas fa-palette"></i>
                    اختر هوية بطاقتك من 10 قوالب
                </h2>
                
                <form action="/create-profile/step2" method="POST" id="templateForm">
                    <!-- بيانات الخطوة السابقة -->
                    <input type="hidden" name="name" value="<%= formData.name %>">
                    <input type="hidden" name="email" value="<%= formData.email %>">
                    <input type="hidden" name="phone" value="<%= formData.phone %>">
                    <input type="hidden" name="title" value="<%= formData.title %>">
                    <input type="hidden" name="company" value="<%= formData.company %>">
                    <input type="hidden" name="bio" value="<%= formData.bio %>">
                    <input type="hidden" name="website" value="<%= formData.website %>">
                    <input type="hidden" name="address" value="<%= formData.address %>">
                    
                    <div class="templates-grid">
                        <!-- 1. القالب العصري -->
                        <label class="template-card" for="template-modern">
                            <input type="radio" name="template" id="template-modern" value="modern" class="radio-input">
                            <div class="selected-icon"><i class="fas fa-check"></i></div>
                            <div class="template-preview preview-modern">عصري</div>
                            <div class="template-info">
                                <h3>القالب العصري</h3>
                                <p>تصميم حديث متدرج بألوان أرجوانية</p>
                                <span class="template-badge"><i class="fas fa-fire"></i> الأكثر طلباً</span>
                            </div>
                        </label>
                        
                        <!-- 2. القالب الكلاسيكي -->
                        <label class="template-card" for="template-classic">
                            <input type="radio" name="template" id="template-classic" value="classic" class="radio-input">
                            <div class="selected-icon"><i class="fas fa-check"></i></div>
                            <div class="template-preview preview-classic">كلاسيكي</div>
                            <div class="template-info">
                                <h3>القالب الكلاسيكي</h3>
                                <p>تصميم رمادي معدني أنيق للمؤسسات</p>
                                <span class="template-badge"><i class="fas fa-crown"></i> احترافي</span>
                            </div>
                        </label>
                        
                        <!-- 3. القالب البسيط -->
                        <label class="template-card" for="template-minimal">
                            <input type="radio" name="template" id="template-minimal" value="minimal" class="radio-input">
                            <div class="selected-icon"><i class="fas fa-check"></i></div>
                            <div class="template-preview preview-minimal">بسيط</div>
                            <div class="template-info">
                                <h3>القالب البسيط</h3>
                                <p>تصميم أبيض نقي يركز على المحتوى</p>
                                <span class="template-badge"><i class="fas fa-leaf"></i> minimalist</span>
                            </div>
                        </label>
                        
                        <!-- 4. القالب الداكن -->
                        <label class="template-card" for="template-dark">
                            <input type="radio" name="template" id="template-dark" value="dark" class="radio-input">
                            <div class="selected-icon"><i class="fas fa-check"></i></div>
                            <div class="template-preview preview-dark">داكن</div>
                            <div class="template-info">
                                <h3>القالب الداكن</h3>
                                <p>تصميم داكن أنيق مناسب للعرض الليلي</p>
                                <span class="template-badge"><i class="fas fa-moon"></i> dark mode</span>
                            </div>
                        </label>
                        
                        <!-- 5. القالب التقني -->
                        <label class="template-card" for="template-tech">
                            <input type="radio" name="template" id="template-tech" value="tech" class="radio-input">
                            <div class="selected-icon"><i class="fas fa-check"></i></div>
                            <div class="template-preview preview-tech">تقني</div>
                            <div class="template-info">
                                <h3>القالب التقني</h3>
                                <p>تصميم بألوان تقنية زرقاء وخضراء</p>
                                <span class="template-badge"><i class="fas fa-microchip"></i> tech</span>
                            </div>
                        </label>
                        
                        <!-- 6. القالب الأنيق -->
                        <label class="template-card" for="template-elegant">
                            <input type="radio" name="template" id="template-elegant" value="elegant" class="radio-input">
                            <div class="selected-icon"><i class="fas fa-check"></i></div>
                            <div class="template-preview preview-elegant">أنيق</div>
                            <div class="template-info">
                                <h3>القالب الأنيق</h3>
                                <p>ألوان أرجوانية ووردية فاخرة</p>
                                <span class="template-badge"><i class="fas fa-gem"></i> elegant</span>
                            </div>
                        </label>
                        
                        <!-- 7. القالب المؤسسي -->
                        <label class="template-card" for="template-corporate">
                            <input type="radio" name="template" id="template-corporate" value="corporate" class="radio-input">
                            <div class="selected-icon"><i class="fas fa-check"></i></div>
                            <div class="template-preview preview-corporate">مؤسسي</div>
                            <div class="template-info">
                                <h3>القالب المؤسسي</h3>
                                <p>ألوان زرقاء احترافية للشركات</p>
                                <span class="template-badge"><i class="fas fa-building"></i> corporate</span>
                            </div>
                        </label>
                        
                        <!-- 8. القالب الإبداعي -->
                        <label class="template-card" for="template-creative">
                            <input type="radio" name="template" id="template-creative" value="creative" class="radio-input">
                            <div class="selected-icon"><i class="fas fa-check"></i></div>
                            <div class="template-preview preview-creative">إبداعي</div>
                            <div class="template-info">
                                <h3>القالب الإبداعي</h3>
                                <p>ألوان برتقالية وحمراء جريئة</p>
                                <span class="template-badge"><i class="fas fa-paint-brush"></i> creative</span>
                            </div>
                        </label>
                        
                        <!-- 9. القالب ثلاثي الأبعاد -->
                        <label class="template-card" for="template-3d">
                            <input type="radio" name="template" id="template-3d" value="3d" class="radio-input">
                            <div class="selected-icon"><i class="fas fa-check"></i></div>
                            <div class="template-preview preview-3d">3D</div>
                            <div class="template-info">
                                <h3>القالب ثلاثي الأبعاد</h3>
                                <p>تصميم مستقبلي بألوان سايبربانك</p>
                                <span class="template-badge"><i class="fas fa-cube"></i> 3D</span>
                            </div>
                        </label>
                        
                        <!-- 10. القالب النيون -->
                        <label class="template-card" for="template-neon">
                            <input type="radio" name="template" id="template-neon" value="neon" class="radio-input">
                            <div class="selected-icon"><i class="fas fa-check"></i></div>
                            <div class="template-preview preview-neon">نيون</div>
                            <div class="template-info">
                                <h3>القالب النيون</h3>
                                <p>تصميم باهر بألوان نيون متوهجة</p>
                                <span class="template-badge"><i class="fas fa-lightbulb"></i> neon</span>
                            </div>
                        </label>
                    </div>

                    <div class="hint">
                        <i class="fas fa-mouse-pointer"></i>
                        اختر القالب الذي يعكس شخصيتك المهنية
                    </div>
                    
                    <div class="form-navigation">
                        <a href="/create-profile" class="btn-prev">
                            <i class="fas fa-arrow-right"></i>
                            السابق
                        </a>
                        <button type="submit" class="btn-next">
                            التالي
                            <i class="fas fa-arrow-left"></i>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            console.log('✨ NFC Pro - 10 قوالب');
            
            // تفعيل اختيار القالب
            const templateCards = document.querySelectorAll('.template-card');
            
            templateCards.forEach(card => {
                card.addEventListener('click', function(e) {
                    templateCards.forEach(c => c.classList.remove('selected'));
                    this.classList.add('selected');
                    const radio = this.querySelector('input[type="radio"]');
                    radio.checked = true;
                    
                    // تأثير بسيط
                    this.style.transform = 'scale(0.98)';
                    setTimeout(() => {
                        this.style.transform = '';
                    }, 200);
                });
            });

            // التحقق من التحديد قبل الإرسال
            const form = document.getElementById('templateForm');
            form.addEventListener('submit', function(e) {
                const selected = document.querySelector('input[name="template"]:checked');
                
                if (!selected) {
                    e.preventDefault();
                    const hint = document.querySelector('.hint');
                    hint.style.color = '#ef4444';
                    hint.innerHTML = '<i class="fas fa-exclamation-circle"></i> الرجاء اختيار قالب أولاً';
                    setTimeout(() => {
                        hint.style.color = '#64748b';
                        hint.innerHTML = '<i class="fas fa-mouse-pointer"></i> اختر القالب الذي يعكس شخصيتك المهنية';
                    }, 3000);
                } else {
                    const btn = document.querySelector('.btn-next');
                    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> جاري التحميل...';
                }
            });

            // تأثيرات hover
            templateCards.forEach(card => {
                card.addEventListener('mouseenter', function() {
                    if (!this.classList.contains('selected')) {
                        this.style.borderColor = '#a5b4fc';
                    }
                });
                card.addEventListener('mouseleave', function() {
                    if (!this.classList.contains('selected')) {
                        this.style.borderColor = '#e2e8f0';
                    }
                });
            });
        });
    </script>
</body>
</html>
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NFC Pro | تم إنشاء بطاقتك بنجاح •  </title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: #f4f9fe;
            min-height: 100vh;
            position: relative;
            overflow-x: hidden;
            color: #1e293b;
        }

        /* خلفية متحركة فاتحة */
        .background {
            position: fixed;
            width: 100vw;
            height: 100vh;
            top: 0;
            left: 0;
            z-index: -1;
            overflow: hidden;
        }

        .gradient-orb {
            position: absolute;
            width: 80vmax;
            height: 80vmax;
            background: radial-gradient(circle at 30% 50%, rgba(147, 197, 253, 0.5) 0%, rgba(165, 180, 252, 0.4) 50%, transparent 70%);
            border-radius: 50%;
            top: -20%;
            right: -20%;
            animation: floatOrb 30s ease-in-out infinite;
        }

        .gradient-orb-2 {
            position: absolute;
            width: 70vmax;
            height: 70vmax;
            background: radial-gradient(circle at 70% 50%, rgba(216, 180, 254, 0.4) 0%, rgba(187, 222, 252, 0.4) 50%, transparent 70%);
            border-radius: 50%;
            bottom: -20%;
            left: -20%;
            animation: floatOrb 35s ease-in-out infinite reverse;
        }

        @keyframes floatOrb {
            0%, 100% { transform: translate(0, 0) scale(1); }
            50% { transform: translate(-5%, 5%) scale(1.05); }
        }

        .particles {
            position: absolute;
            width: 100%;
            height: 100%;
            background-image: 
                radial-gradient(circle at 20% 30%, rgba(59, 130, 246, 0.08) 1.5px, transparent 1.5px),
                radial-gradient(circle at 80% 70%, rgba(139, 92, 246, 0.06) 1px, transparent 1px),
                radial-gradient(circle at 40% 80%, rgba(37, 99, 235, 0.07) 1px, transparent 1px);
            background-size: 130px 130px;
            animation: moveParticles 50s linear infinite;
            opacity: 0.5;
        }

        @keyframes moveParticles {
            0% { background-position: 0 0, 0 0, 0 0; }
            100% { background-position: 200px 200px, -150px 100px, 100px -200px; }
        }

        /* كونفيتي ملون فاتح */
        .confetti {
            position: fixed;
            width: 100%;
            height: 100%;
            top: 0;
            left: 0;
            pointer-events: none;
            z-index: 2;
        }

        .confetti-piece {
            position: absolute;
            width: 10px;
            height: 25px;
            background: linear-gradient(135deg, #3b82f6, #8b5cf6);
            opacity: 0.4;
            animation: confettiFall 3s ease-in-out infinite;
        }

        @keyframes confettiFall {
            0% {
                transform: translateY(-100vh) rotate(0deg);
            }
            100% {
                transform: translateY(100vh) rotate(360deg);
            }
        }

        /* الحاوية الرئيسية */
        .profile-creation {
            min-height: 100vh;
            padding: 40px 20px;
            position: relative;
            z-index: 1;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .creation-container {
            max-width: 1100px;
            width: 100%;
            margin: 0 auto;
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(18px);
            border-radius: 48px;
            overflow: hidden;
            box-shadow: 
                0 30px 60px -20px rgba(0, 80, 120, 0.2),
                0 0 0 1px rgba(255, 255, 255, 0.8) inset;
            border: 1px solid rgba(255,255,255,0.7);
            animation: slideUp 0.8s cubic-bezier(0.2,0.9,0.3,1);
        }

        @keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(40px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* رأس الخطوات */
        .steps-header {
            padding: 30px 40px;
            border-bottom: 1px solid rgba(0,0,0,0.05);
            background: rgba(255,255,255,0.3);
        }

        .steps-progress {
            display: flex;
            justify-content: space-between;
            position: relative;
            margin-bottom: 10px;
        }

        .steps-progress::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 60px;
            right: 60px;
            height: 2px;
            background: linear-gradient(90deg, transparent, rgba(0,0,0,0.1), transparent);
            transform: translateY(-50%);
            z-index: 1;
        }

        .step-item {
            position: relative;
            z-index: 2;
            background: white;
            backdrop-filter: blur(10px);
            padding: 12px 28px;
            border-radius: 100px;
            display: flex;
            align-items: center;
            gap: 12px;
            color: #64748b;
            border: 1px solid rgba(0,0,0,0.05);
            box-shadow: 0 4px 10px rgba(0,0,0,0.02);
            font-weight: 500;
        }

        .step-item.completed {
            background: #f0fdf4;
            border-color: #86efac;
            color: #166534;
        }

        .step-number {
            width: 32px;
            height: 32px;
            background: #e2e8f0;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            font-size: 0.9rem;
            color: #334155;
        }

        .completed .step-number {
            background: linear-gradient(145deg, #3b82f6, #8b5cf6);
            color: white;
        }

        .step-item i {
            color: #22c55e;
            font-size: 0.9rem;
        }

        /* قسم النجاح */
        .success-section {
            padding: 60px 40px;
        }

        .success-icon {
            text-align: center;
            margin-bottom: 30px;
            position: relative;
        }

        .success-icon i {
            font-size: 6rem;
            background: linear-gradient(145deg, #22c55e, #3b82f6);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            animation: successPop 1s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        @keyframes successPop {
            0% {
                transform: scale(0) rotate(-180deg);
            }
            50% {
                transform: scale(1.2) rotate(10deg);
            }
            100% {
                transform: scale(1) rotate(0);
            }
        }

        .success-section h2 {
            color: #0f172a;
            font-size: 2.5rem;
            font-weight: 800;
            text-align: center;
            margin-bottom: 10px;
            background: linear-gradient(145deg, #2563eb, #7c3aed);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            animation: glowText 2s ease-in-out infinite;
        }

        @keyframes glowText {
            0%, 100% { text-shadow: 0 0 20px rgba(59, 130, 246, 0.3); }
            50% { text-shadow: 0 0 40px rgba(59, 130, 246, 0.5); }
        }

        .success-section .subtitle {
            color: #64748b;
            font-size: 1.2rem;
            text-align: center;
            margin-bottom: 50px;
        }

        /* أزرار CTA الرئيسية */
        .cta-section {
            margin-bottom: 40px;
        }

        .cta-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin-bottom: 20px;
        }

        .cta-card {
            background: white;
            border: 1px solid #e2e8f0;
            border-radius: 32px;
            padding: 30px 20px;
            text-align: center;
            cursor: pointer;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            overflow: hidden;
            opacity: 0;
            transform: translateY(30px);
            animation: cardAppear 0.6s ease-out forwards;
            box-shadow: 0 10px 25px -12px rgba(0,0,0,0.1);
        }

        .cta-card:nth-child(1) { animation-delay: 0.2s; }
        .cta-card:nth-child(2) { animation-delay: 0.4s; }
        .cta-card:nth-child(3) { animation-delay: 0.6s; }

        @keyframes cardAppear {
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .cta-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(145deg, #eef2ff, #ffffff);
            transform: translateX(-100%);
            transition: transform 0.6s ease;
        }

        .cta-card:hover {
            transform: translateY(-8px);
            border-color: #3b82f6;
            box-shadow: 0 30px 40px -20px #3b82f6;
        }

        .cta-card:hover::before {
            transform: translateX(0);
        }

        .cta-icon {
            font-size: 3rem;
            margin-bottom: 20px;
            background: linear-gradient(145deg, #2563eb, #a78bfa);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            transition: all 0.3s ease;
            position: relative;
            z-index: 2;
        }

        .cta-card:hover .cta-icon {
            transform: scale(1.1) rotate(5deg);
        }

        .cta-title {
            color: #0f172a;
            font-size: 1.3rem;
            font-weight: 700;
            margin-bottom: 10px;
            position: relative;
            z-index: 2;
        }

        .cta-description {
            color: #64748b;
            font-size: 0.95rem;
            margin-bottom: 20px;
            line-height: 1.6;
            position: relative;
            z-index: 2;
        }

        .cta-price {
            display: inline-block;
            padding: 8px 25px;
            background: linear-gradient(145deg, #2563eb, #8b5cf6);
            border-radius: 100px;
            color: white;
            font-weight: 700;
            font-size: 1.1rem;
            box-shadow: 0 10px 20px -10px #3b82f6;
            position: relative;
            z-index: 2;
        }

        .cta-price.free {
            background: #e2e8f0;
            color: #334155;
            box-shadow: none;
        }

        /* صف الأزرار الإضافية */
        .cta-row {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
            margin-top: 20px;
        }

        .cta-button {
            background: white;
            border: 1px solid #e2e8f0;
            border-radius: 28px;
            padding: 25px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s ease;
            text-decoration: none;
            display: block;
            opacity: 0;
            transform: translateY(30px);
            animation: cardAppear 0.6s ease-out 0.8s forwards;
            box-shadow: 0 10px 25px -12px rgba(0,0,0,0.05);
        }

        .cta-button:hover {
            transform: translateY(-5px);
            border-color: #3b82f6;
            background: #f8fafc;
        }

        .cta-button i {
            font-size: 2.5rem;
            background: linear-gradient(145deg, #2563eb, #a78bfa);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 15px;
            transition: transform 0.3s ease;
        }

        .cta-button:hover i {
            transform: scale(1.1);
        }

        .cta-button h4 {
            color: #0f172a;
            margin-bottom: 8px;
            font-size: 1.2rem;
        }

        .cta-button p {
            color: #64748b;
            font-size: 0.9rem;
        }

        /* بطاقات الملف الشخصي */
        .profile-card {
            background: white;
            border: 1px solid #e2e8f0;
            border-radius: 32px;
            padding: 30px;
            margin-bottom: 30px;
            transition: all 0.3s ease;
            opacity: 0;
            transform: translateY(30px);
            animation: cardAppear 0.6s ease-out 1s forwards;
            box-shadow: 0 10px 25px -12px rgba(0,0,0,0.05);
        }

        .profile-card:hover {
            border-color: #a5b4fc;
            box-shadow: 0 20px 35px -18px #3b82f6;
        }

        .profile-header {
            display: flex;
            align-items: center;
            gap: 15px;
            margin-bottom: 20px;
        }

        .profile-header i {
            font-size: 2rem;
            background: linear-gradient(145deg, #2563eb, #a78bfa);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .profile-header h3 {
            color: #0f172a;
            font-size: 1.3rem;
            margin: 0;
        }

        .profile-url {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 24px;
            padding: 15px 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 15px;
            transition: all 0.3s ease;
        }

        .profile-url:hover {
            border-color: #3b82f6;
            background: #f0f9ff;
        }

        .profile-url span {
            color: #0f172a;
            font-family: monospace;
            font-size: 1rem;
            word-break: break-all;
            direction: ltr;
            text-align: left;
        }

        .copy-btn {
            background: linear-gradient(145deg, #3b82f6, #8b5cf6);
            color: white;
            border: none;
            padding: 8px 22px;
            border-radius: 40px;
            cursor: pointer;
            transition: all 0.3s ease;
            white-space: nowrap;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 0.95rem;
            font-weight: 500;
        }

        .copy-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px -5px #3b82f6;
        }

        .copy-btn i {
            font-size: 1rem;
        }

        .physical-badge {
            background: linear-gradient(145deg, #3b82f6, #8b5cf6);
            color: white;
            border: none;
            padding: 14px 28px;
            border-radius: 40px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            width: 100%;
            margin-top: 15px;
        }

        .physical-badge:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px -5px #3b82f6;
        }

        /* خيارات التصدير */
        .options-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin: 30px 0;
            opacity: 0;
            transform: translateY(30px);
            animation: cardAppear 0.6s ease-out 1.2s forwards;
        }

        .option-card {
            background: white;
            border: 1px solid #e2e8f0;
            border-radius: 28px;
            padding: 25px 20px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 10px 25px -12px rgba(0,0,0,0.05);
        }

        .option-card:hover {
            transform: translateY(-5px);
            border-color: #3b82f6;
            background: #f8fafc;
        }

        .option-card i {
            font-size: 2.5rem;
            background: linear-gradient(145deg, #2563eb, #a78bfa);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 15px;
            transition: transform 0.3s ease;
        }

        .option-card:hover i {
            transform: scale(1.1) rotate(5deg);
        }

        .option-card h3 {
            color: #0f172a;
            margin-bottom: 8px;
            font-size: 1.1rem;
            font-weight: 600;
        }

        .option-card p {
            color: #64748b;
            font-size: 0.9rem;
            line-height: 1.6;
        }

        /* ملاحظة */
        .note-box {
            background: #eef2ff;
            border: 1px solid #a5b4fc;
            border-radius: 24px;
            padding: 20px 25px;
            margin: 30px 0;
            color: #1e293b;
            display: flex;
            align-items: center;
            gap: 15px;
            opacity: 0;
            transform: translateY(30px);
            animation: cardAppear 0.6s ease-out 1.4s forwards;
        }

        .note-box i {
            color: #3b82f6;
            font-size: 1.5rem;
        }

        .note-box p {
            color: #334155;
            font-size: 0.95rem;
            line-height: 1.6;
        }

        /* أزرار الإجراءات */
        .action-buttons {
            display: flex;
            gap: 20px;
            justify-content: center;
            margin: 40px 0 20px;
            opacity: 0;
            transform: translateY(30px);
            animation: cardAppear 0.6s ease-out 1.6s forwards;
        }

        .btn-primary,
        .btn-secondary {
            padding: 14px 42px;
            border-radius: 40px;
            font-size: 1.1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.25s ease;
            display: flex;
            align-items: center;
            gap: 12px;
            border: none;
            text-decoration: none;
            position: relative;
            overflow: hidden;
        }

        .btn-primary {
            background: linear-gradient(145deg, #3b82f6, #8b5cf6);
            color: white;
            box-shadow: 0 12px 28px -10px #3b82f6;
        }

        .btn-secondary {
            background: white;
            color: #334155;
            border: 1px solid #e2e8f0;
        }

        .btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 20px 35px -8px #3b82f6;
        }

        .btn-secondary:hover {
            background: #f8fafc;
            border-color: #cbd5e1;
            transform: translateY(-2px);
        }

        /* Modal */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(8px);
            z-index: 1000;
            align-items: center;
            justify-content: center;
            animation: fadeIn 0.3s ease;
        }

        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        .modal-content {
            background: white;
            border: 1px solid #e2e8f0;
            border-radius: 40px;
            padding: 40px;
            max-width: 450px;
            width: 90%;
            max-height: 80vh;
            overflow-y: auto;
            animation: modalSlideUp 0.4s ease-out;
            box-shadow: 0 30px 60px -20px rgba(0,0,0,0.3);
        }

        @keyframes modalSlideUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .modal-content h3 {
            color: #0f172a;
            margin-bottom: 25px;
            font-size: 1.8rem;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .modal-content h3 i {
            color: #3b82f6;
        }

        .modal-content label {
            display: block;
            margin-bottom: 10px;
            color: #334155;
            font-weight: 600;
        }

        .modal-content select {
            width: 100%;
            padding: 15px 20px;
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 24px;
            margin-bottom: 20px;
            font-size: 1rem;
            color: #0f172a;
            font-family: 'Plus Jakarta Sans', sans-serif;
            cursor: pointer;
        }

        .modal-content select:focus {
            outline: none;
            border-color: #3b82f6;
        }

        .modal-buttons {
            display: flex;
            gap: 15px;
            margin-top: 30px;
        }

        .modal-btn {
            flex: 1;
            padding: 15px;
            border: none;
            border-radius: 40px;
            cursor: pointer;
            font-size: 1rem;
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .modal-btn.cancel {
            background: white;
            color: #334155;
            border: 1px solid #e2e8f0;
        }

        .modal-btn.confirm {
            background: linear-gradient(145deg, #3b82f6, #8b5cf6);
            color: white;
        }

        .modal-btn:hover {
            transform: translateY(-2px);
        }

        /* زر عائم */
        .floating-cta {
            position: fixed;
            bottom: 30px;
            left: 30px;
            background: linear-gradient(145deg, #3b82f6, #8b5cf6);
            color: white;
            width: 70px;
            height: 70px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            box-shadow: 0 10px 30px #3b82f6;
            transition: all 0.3s ease;
            z-index: 999;
            border: none;
            animation: float 3s ease-in-out infinite;
        }

        @keyframes float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }

        .floating-cta:hover {
            transform: scale(1.1);
            box-shadow: 0 20px 40px #3b82f6;
        }

        .floating-cta i {
            font-size: 1.8rem;
        }

        .floating-tooltip {
            position: absolute;
            left: 80px;
            background: white;
            color: #0f172a;
            padding: 10px 20px;
            border-radius: 40px;
            font-size: 0.9rem;
            white-space: nowrap;
            border: 1px solid #e2e8f0;
            opacity: 0;
            transform: translateX(-10px);
            transition: all 0.3s ease;
            pointer-events: none;
            box-shadow: 0 10px 25px -10px rgba(0,0,0,0.1);
        }

        .floating-cta:hover .floating-tooltip {
            opacity: 1;
            transform: translateX(0);
        }

        /* تصميم متجاوب */
        @media (max-width: 768px) {
            .cta-grid,
            .options-grid,
            .cta-row {
                grid-template-columns: 1fr;
            }
            
            .action-buttons {
                flex-direction: column;
            }
            
            .profile-url {
                flex-direction: column;
                gap: 15px;
            }
            
            .profile-url span {
                text-align: center;
            }
            
            .copy-btn {
                width: 100%;
                justify-content: center;
            }
            
            .steps-progress {
                flex-direction: column;
                gap: 12px;
            }
            
            .steps-progress::before {
                display: none;
            }
            
            .step-item {
                width: 100%;
            }
            
            .success-section {
                padding: 40px 20px;
            }
            
            .success-section h2 {
                font-size: 2rem;
            }
        }

        /* تخصيص شريط التمرير */
        ::-webkit-scrollbar {
            width: 10px;
        }

        ::-webkit-scrollbar-track {
            background: #e2e8f0;
        }

        ::-webkit-scrollbar-thumb {
            background: linear-gradient(145deg, #a5b4fc, #bae6fd);
            border-radius: 10px;
        }

        /* إشعارات */
        .notification {
            position: fixed;
            bottom: 100px;
            left: 50%;
            transform: translateX(-50%);
            background: white;
            color: #0f172a;
            padding: 15px 30px;
            border-radius: 50px;
            border: 1px solid #e2e8f0;
            box-shadow: 0 20px 40px -15px rgba(0,0,0,0.2);
            z-index: 1001;
            animation: notificationSlide 0.3s ease;
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: 500;
        }

        @keyframes notificationSlide {
            from {
                opacity: 0;
                transform: translate(-50%, 20px);
            }
            to {
                opacity: 1;
                transform: translate(-50%, 0);
            }
        }

        .notification i {
            color: #3b82f6;
        }
    </style>
</head>
<body>
    <div class="background">
        <div class="gradient-orb"></div>
        <div class="gradient-orb-2"></div>
        <div class="particles"></div>
    </div>

    <!-- كونفيتي احتفالي ملون فاتح -->
    <div class="confetti" id="confetti"></div>

    <div class="profile-creation">
        <div class="creation-container">
            <div class="steps-header">
                <div class="steps-progress">
                    <div class="step-item completed">
                        <span class="step-number">1</span>
                        <span> الخطوة الاولى</span>
                        <i class="fas fa-check"></i>
                    </div>
                    <div class="step-item completed">
                        <span class="step-number">2</span>
                        <span> الخطوة الثانية</span>
                        <i class="fas fa-check"></i>
                    </div>
                    <div class="step-item completed">
                        <span class="step-number">3</span>
                        <span>الخطوة الثالثة </span>
                        <i class="fas fa-check"></i>
                    </div>
                    <div class="step-item completed">
                        <span class="step-number">4</span>
                        <span>التأكيد</span>
                        <i class="fas fa-check"></i>
                    </div>
                </div>
            </div>
            
            <div class="success-section">
                <div class="success-icon">
                    <i class="fas fa-check-circle"></i>
                </div>
                
                <h2>تهانينا! بطاقتك الذكية جاهزة</h2>
                <p class="subtitle">اختر كيف تريد استخدام هويتك الرقمية</p>
                
                <!-- أزرار CTA الرئيسية -->
                <div class="cta-section">
                    <div class="cta-grid">
                        <!-- زر 1: طلب بطاقة NFC مادية -->
                        <div class="cta-card" onclick="orderPhysicalCard()">
                            <div class="cta-icon">
                                <i class="fas fa-id-card"></i>
                            </div>
                            <div class="cta-title">بطاقة NFC مادية</div>
                            <div class="cta-description">بطاقة احترافية مع شريحة NFC ورمز QR</div>
                            <div class="cta-price">٩٩ ر.س</div>
                        </div>
                        
                        <!-- زر 2: مشاركة الملف الرقمي -->
                        <div class="cta-card" onclick="shareProfile()">
                            <div class="cta-icon">
                                <i class="fas fa-share-alt"></i>
                            </div>
                            <div class="cta-title">مشاركة الملف الرقمي</div>
                            <div class="cta-description">شارك رابط بطاقتك مع أي شخص</div>
                            <div class="cta-price free">مجاناً</div>
                        </div>
                        
                        <!-- زر 3: تنزيل رمز QR -->
                        <div class="cta-card" onclick="downloadQR()">
                            <div class="cta-icon">
                                <i class="fas fa-qrcode"></i>
                            </div>
                            <div class="cta-title">رمز QR</div>
                            <div class="cta-description">تنزيل رمز QR لطباعته أو مشاركته</div>
                            <div class="cta-price free">مجاناً</div>
                        </div>
                    </div>
                    
                    <!-- أزرار إضافية -->
                    <div class="cta-row">
                        <div class="cta-button" onclick="downloadVCard()">
                            <i class="fas fa-address-card"></i>
                            <h4>تنزيل vCard</h4>
                            <p>ملف جهة اتصال جاهز</p>
                        </div>
                        
                        <div class="cta-button" onclick="copyProfileLink()">
                            <i class="fas fa-link"></i>
                            <h4>نسخ الرابط</h4>
                            <p>شاركه مع أي شخص</p>
                        </div>
                    </div>
                </div>
                
                <!-- النسخة المادية -->
                <div class="profile-card">
                    <div class="profile-header">
                        <i class="fas fa-id-card"></i>
                        <h3>النسخة المادية</h3>
                    </div>
                    
                    <div class="profile-url">
                        <span><%= profileUrl %></span>
                        <button class="copy-btn" onclick="copyToClipboard('<%= profileUrl %>')">
                            <i class="fas fa-copy"></i> نسخ
                        </button>
                    </div>
                    
                    <p style="color: #64748b; margin: 10px 0;">
                        <i class="fas fa-wifi" style="color: #3b82f6; margin-left: 5px;"></i>
                        NFC · بطاقة بلاستيكية عالية الجودة مع شريحة NFC
                    </p>
                    
                    <button onclick="orderPhysicalCard()" class="physical-badge">
                        <i class="fas fa-shopping-cart"></i>
                        اطلب بطاقتك الآن
                    </button>
                </div>
                
                <!-- النسخة الرقمية -->
                <div class="profile-card">
                    <div class="profile-header">
                        <i class="fas fa-link"></i>
                        <h3>النسخة الرقمية</h3>
                    </div>
                    
                    <p style="color: #64748b; margin: 10px 0;">
                        <i class="fas fa-globe" style="color: #3b82f6; margin-left: 5px;"></i>
                        رابط فريد يؤدي مباشرة إلى ملفك الشخصي
                    </p>
                    
                    <div class="profile-url">
                        <span><%= profileUrl %></span>
                        <button class="copy-btn" onclick="copyToClipboard('<%= profileUrl %>')">
                            <i class="fas fa-copy"></i> نسخ
                        </button>
                    </div>
                </div>
                
                <!-- خيارات التصدير الإضافية -->
                <h3 style="color: #0f172a; text-align: right; margin: 40px 0 20px;">خيارات إضافية</h3>
                
                <div class="options-grid">
                    <div class="option-card" onclick="downloadQR()">
                        <i class="fas fa-qrcode"></i>
                        <h3>رمز QR</h3>
                        <p>استخدمه في بطاقاتك أو موقعك</p>
                    </div>
                    
                    <div class="option-card" onclick="downloadVCard()">
                        <i class="fas fa-address-card"></i>
                        <h3>vCard</h3>
                        <p>ملف جهة اتصال للهاتف</p>
                    </div>
                    
                    <div class="option-card" onclick="shareProfile()">
                        <i class="fas fa-share-alt"></i>
                        <h3>مشاركة</h3>
                        <p>عبر وسائل التواصل</p>
                    </div>
                </div>
                
                <!-- ملاحظة -->
                
                <!-- أزرار الإجراءات -->
                <div class="action-buttons">
                    
                    <a href="/" class="btn-primary">
                        <i class="fas fa-home"></i>
                        العودة للرئيسية
                    </a>
                </div>
            </div>
        </div>
    </div>
    
    <!-- نافذة منبثقة للطلب -->
    <div class="modal" id="orderModal">
        <div class="modal-content">
            <h3>
                <i class="fas fa-shopping-cart"></i>
                طلب بطاقة NFC
            </h3>
            
            <div style="margin-bottom: 20px;">
                <label>عدد البطاقات:</label>
                <select id="cardQuantity">
                    <option value="1">١ بطاقة - ٩٩ ر.س</option>
                    <option value="5">٥ بطاقات - ٤٤٩ ر.س (وفر ٤٦ ر.س)</option>
                    <option value="10">١٠ بطاقات - ٨٤٩ ر.س (وفر ١٤١ ر.س)</option>
                    <option value="25">٢٥ بطاقة - ١٩٩٩ ر.س (وفر ٤٧٦ ر.س)</option>
                </select>
            </div>
            
            <div style="margin-bottom: 20px;">
                <label>نوع البطاقة:</label>
                <select id="cardType">
                    <option value="standard">ورقية </option>
                    
                </select>
            </div>
            
            <div class="modal-buttons">
                <button class="modal-btn cancel" onclick="closeModal()">إلغاء</button>
                <button class="modal-btn confirm" onclick="confirmOrder()">تأكيد الطلب</button>
            </div>
        </div>
    </div>
    
    <!-- زر عائم -->
    <div class="floating-cta" onclick="orderPhysicalCard()">
        <i class="fas fa-shopping-cart"></i>
        <span class="floating-tooltip">اطلب بطاقتك الآن</span>
    </div>
    
    <script>
        // استقبال المتغيرات من الخادم
        const profileId = '<%= profileId %>';
        const baseUrl = '<%= profileUrl.split('/p/')[0] %>';
        const profileLink = '<%= profileUrl %>';
        const whatsappNumber = '<%= whatsappNumber %>';
        const profileName = '<%= formData.name %>';
        const profileTitle = '<%= formData.title || "" %>';
        const profileCompany = '<%= formData.company || "" %>';
        const profileEmail = '<%= formData.email %>';
        const profilePhone = '<%= formData.phone %>';

        console.log('📌 بيانات البطاقة:', { profileId, profileLink, whatsappNumber });

        // إنشاء الكونفيتي
        function createConfetti() {
            const confettiContainer = document.getElementById('confetti');
            for (let i = 0; i < 40; i++) {
                const piece = document.createElement('div');
                piece.className = 'confetti-piece';
                piece.style.left = Math.random() * 100 + '%';
                piece.style.animationDelay = Math.random() * 2 + 's';
                piece.style.background = `linear-gradient(135deg, hsl(${Math.random() * 360}, 70%, 60%), hsl(${Math.random() * 360}, 70%, 70%))`;
                confettiContainer.appendChild(piece);
            }
        }

        // إظهار الإشعارات
        function showNotification(message, type = 'success') {
            const notification = document.createElement('div');
            notification.className = 'notification';
            notification.innerHTML = `
                <i class="fas ${type === 'success' ? 'fa-check-circle' : 'fa-info-circle'}" style="color: #3b82f6;"></i>
                ${message}
            `;
            document.body.appendChild(notification);
            
            setTimeout(() => {
                notification.style.animation = 'notificationSlide 0.3s ease reverse';
                setTimeout(() => {
                    notification.remove();
                }, 300);
            }, 3000);
        }

        // نسخ الرابط
        function copyToClipboard(text) {
            navigator.clipboard.writeText(text).then(() => {
                showNotification('✅ تم نسخ الرابط بنجاح!');
            }).catch(() => {
                // Fallback للنسخ
                const textarea = document.createElement('textarea');
                textarea.value = text;
                document.body.appendChild(textarea);
                textarea.select();
                document.execCommand('copy');
                document.body.removeChild(textarea);
                showNotification('✅ تم نسخ الرابط بنجاح!');
            });
        }
        
        function copyProfileLink() {
            copyToClipboard(profileLink);
        }
        
        // طلب بطاقة مادية
        function orderPhysicalCard() {
            document.getElementById('orderModal').style.display = 'flex';
        }
        
        // إغلاق النافذة
        function closeModal() {
            document.getElementById('orderModal').style.display = 'none';
        }
        
        // تأكيد الطلب
        function confirmOrder() {
            const quantity = document.getElementById('cardQuantity').value;
            const cardTypeElement = document.getElementById('cardType');
            const cardType = cardTypeElement.options[cardTypeElement.selectedIndex].text;
            
            showNotification('📱 جاري تحويلك إلى واتساب...');
            
            setTimeout(() => {
                const message = encodeURIComponent(
                    `طلب بطاقة NFC:\n` +
                    `----------------\n` +
                    `العدد: ${quantity}\n` +
                    `النوع: ${cardType}\n` +
                    `الاسم: ${profileName}\n` +
                    `الرابط: ${profileLink}\n` +
                    `----------------\n` +
                    `تاريخ الطلب: ${new Date().toLocaleDateString('ar-SA')}`
                );
                window.open(`https://wa.me/${whatsappNumber}?text=${message}`, '_blank');
                closeModal();
            }, 1500);
        }
        
        // تنزيل QR
        function downloadQR() {
            showNotification('📱 جاري إنشاء رمز QR...');
            const qrUrl = `https://api.qrserver.com/v1/create-qr-code/?size=300x300&data=${encodeURIComponent(profileLink)}`;
            window.open(qrUrl, '_blank');
        }
        
        // تنزيل vCard
        function downloadVCard() {
            const vCardData = `BEGIN:VCARD
VERSION:3.0
FN:${profileName}
TITLE:${profileTitle}
ORG:${profileCompany}
EMAIL:${profileEmail}
TEL:${profilePhone}
URL:${profileLink}
NOTE:هوية ذكية من نظام NFC
END:VCARD`;
            
            const blob = new Blob([vCardData], { type: 'text/vcard' });
            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `${profileName}.vcf`;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            window.URL.revokeObjectURL(url);
            
            showNotification('✅ تم تنزيل بطاقة الاتصال');
        }
        
        // مشاركة الملف
        function shareProfile() {
            if (navigator.share) {
                navigator.share({
                    title: `هوية ${profileName} الذكية`,
                    text: 'تفقد ملفي الشخصي',
                    url: profileLink
                }).catch(() => {
                    copyProfileLink();
                });
            } else {
                copyProfileLink();
            }
        }
        
        // إغلاق المودال عند النقر خارجه
        window.onclick = function(event) {
            const modal = document.getElementById('orderModal');
            if (event.target === modal) {
                modal.style.display = 'none';
            }
        }

        // تشغيل الكونفيتي عند تحميل الصفحة
        document.addEventListener('DOMContentLoaded', function() {
            createConfetti();
            console.log('🎉 NFC Pro - تم إنشاء البطاقة بنجاح!');
            
            // إزالة الكونفيتي بعد 5 ثوان
            setTimeout(() => {
                const confetti = document.getElementById('confetti');
                confetti.style.opacity = '0';
                confetti.style.transition = 'opacity 1s';
                setTimeout(() => {
                    confetti.innerHTML = '';
                }, 1000);
            }, 5000);
        });
    </script>
</body>
</html>
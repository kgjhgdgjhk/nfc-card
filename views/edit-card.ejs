<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>تعديل البطاقة - <%= card.name %> | NFC Pro</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <style>
        /* نفس الأنماط السابقة - لا تغيير */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: #f4f9fe;
            color: #1e293b;
            min-height: 100vh;
            position: relative;
        }

        /* خلفية متحركة فاتحة */
        .background {
            position: fixed;
            width: 100vw;
            height: 100vh;
            top: 0;
            left: 0;
            z-index: -1;
            overflow: hidden;
        }

        .gradient-orb {
            position: absolute;
            width: 80vmax;
            height: 80vmax;
            background: radial-gradient(circle at 30% 50%, rgba(147, 197, 253, 0.5) 0%, rgba(165, 180, 252, 0.4) 50%, transparent 70%);
            border-radius: 50%;
            top: -20%;
            right: -20%;
            animation: floatOrb 30s ease-in-out infinite;
        }

        .gradient-orb-2 {
            position: absolute;
            width: 70vmax;
            height: 70vmax;
            background: radial-gradient(circle at 70% 50%, rgba(216, 180, 254, 0.4) 0%, rgba(187, 222, 252, 0.4) 50%, transparent 70%);
            border-radius: 50%;
            bottom: -20%;
            left: -20%;
            animation: floatOrb 35s ease-in-out infinite reverse;
        }

        @keyframes floatOrb {
            0%, 100% { transform: translate(0, 0) scale(1); }
            50% { transform: translate(-5%, 5%) scale(1.05); }
        }

        .particles {
            position: absolute;
            width: 100%;
            height: 100%;
            background-image: 
                radial-gradient(circle at 20% 30%, rgba(59, 130, 246, 0.06) 1.5px, transparent 1.5px),
                radial-gradient(circle at 80% 70%, rgba(139, 92, 246, 0.05) 1px, transparent 1px);
            background-size: 130px 130px;
            animation: moveParticles 50s linear infinite;
            opacity: 0.4;
        }

        @keyframes moveParticles {
            0% { background-position: 0 0, 0 0; }
            100% { background-position: 200px 200px, -150px 100px; }
        }

        /* الحاوية الرئيسية */
        .edit-container {
            max-width: 900px;
            margin: 0 auto;
            padding: 30px 20px;
            position: relative;
            z-index: 1;
        }

        /* الهيدر */
        .edit-header {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(18px);
            border-radius: 40px;
            padding: 30px;
            margin-bottom: 30px;
            border: 1px solid rgba(255,255,255,0.7);
            box-shadow: 0 20px 40px -20px rgba(0,80,120,0.2);
            display: flex;
            align-items: center;
            gap: 20px;
            flex-wrap: wrap;
        }

        .back-button {
            background: white;
            border: 1px solid #e2e8f0;
            border-radius: 50px;
            padding: 12px 25px;
            color: #334155;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            font-weight: 500;
            transition: all 0.3s ease;
        }

        .back-button:hover {
            background: #f8fafc;
            border-color: #3b82f6;
            color: #3b82f6;
            transform: translateX(5px);
        }

        .edit-header h1 {
            font-size: 1.8rem;
            font-weight: 700;
            color: #0f172a;
            display: flex;
            align-items: center;
            gap: 15px;
            flex: 1;
        }

        .edit-header h1 i {
            background: linear-gradient(145deg, #3b82f6, #8b5cf6);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .card-id-badge {
            background: #eef2ff;
            color: #3b82f6;
            padding: 8px 20px;
            border-radius: 40px;
            font-size: 0.9rem;
            font-weight: 600;
            border: 1px solid #a5b4fc;
        }

        /* قسم التعديل */
        .edit-section {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(18px);
            border-radius: 40px;
            padding: 30px;
            margin-bottom: 30px;
            border: 1px solid rgba(255,255,255,0.7);
            box-shadow: 0 20px 40px -20px rgba(0,80,120,0.2);
        }

        .edit-section h2 {
            font-size: 1.5rem;
            font-weight: 600;
            color: #0f172a;
            margin-bottom: 25px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .edit-section h2 i {
            background: linear-gradient(145deg, #3b82f6, #8b5cf6);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        /* رسائل التنبيه */
        .alert {
            padding: 16px 24px;
            border-radius: 20px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 12px;
            font-weight: 500;
            animation: slideDown 0.3s ease;
        }

        @keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .alert.success {
            background: #f0fdf4;
            border: 1px solid #86efac;
            color: #166534;
        }

        .alert.error {
            background: #fef2f2;
            border: 1px solid #fecaca;
            color: #991b1b;
        }

        .alert i {
            font-size: 1.2rem;
        }

        /* النموذج */
        .edit-form {
            background: white;
            border-radius: 32px;
            padding: 30px;
            border: 1px solid #e2e8f0;
            box-shadow: 0 10px 25px -12px rgba(0,0,0,0.1);
        }

        .form-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
            margin-bottom: 25px;
        }

        .form-group {
            margin-bottom: 0;
        }

        .form-group.full-width {
            grid-column: 1 / -1;
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            color: #334155;
            font-weight: 600;
            font-size: 0.95rem;
        }

        .form-group input,
        .form-group textarea,
        .form-group select {
            width: 100%;
            padding: 14px 18px;
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 18px;
            font-size: 0.95rem;
            color: #0f172a;
            transition: all 0.3s ease;
            font-family: 'Plus Jakarta Sans', sans-serif;
        }

        .form-group input:focus,
        .form-group textarea:focus,
        .form-group select:focus {
            outline: none;
            border-color: #3b82f6;
            background: white;
            box-shadow: 0 4px 12px rgba(59,130,246,0.1);
        }

        .form-group input[dir="ltr"] {
            text-align: left;
        }

        .form-group input:read-only {
            background: #f1f5f9;
            color: #64748b;
            cursor: not-allowed;
        }

        /* أزرار الإجراءات */
        .form-actions {
            display: flex;
            gap: 15px;
            margin-top: 30px;
            padding-top: 20px;
            border-top: 1px solid #e2e8f0;
            flex-wrap: wrap;
        }

        .btn-save {
            background: linear-gradient(145deg, #3b82f6, #8b5cf6);
            color: white;
            border: none;
            padding: 16px 40px;
            border-radius: 40px;
            font-size: 1.1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 12px;
            box-shadow: 0 12px 28px -10px #3b82f6;
        }

        .btn-save:hover {
            transform: translateY(-3px);
            box-shadow: 0 20px 35px -8px #3b82f6;
        }

        .btn-cancel {
            background: white;
            color: #334155;
            border: 1px solid #e2e8f0;
            padding: 16px 40px;
            border-radius: 40px;
            font-size: 1.1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
        }

        .btn-cancel:hover {
            background: #f8fafc;
            border-color: #cbd5e1;
            transform: translateY(-2px);
        }

        .btn-delete {
            background: #fef2f2;
            color: #dc2626;
            border: 1px solid #fecaca;
            padding: 16px 40px;
            border-radius: 40px;
            font-size: 1.1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 12px;
            margin-right: auto;
        }

        .btn-delete:hover {
            background: #fee2e2;
            border-color: #f87171;
            transform: translateY(-2px);
        }

        /* معاينة البطاقة */
        .preview-section {
            margin-top: 20px;
        }

        .preview-toggle {
            background: white;
            border: 1px solid #e2e8f0;
            border-radius: 40px;
            padding: 12px 25px;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-bottom: 20px;
        }

        .preview-toggle:hover {
            border-color: #3b82f6;
            color: #3b82f6;
        }

        .preview-card {
            background: white;
            border-radius: 28px;
            padding: 30px;
            border: 1px solid #e2e8f0;
            box-shadow: 0 10px 25px -12px rgba(0,0,0,0.1);
            display: none;
        }

        .preview-card.show {
            display: block;
            animation: fadeIn 0.3s ease;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .btn-view {
            background: linear-gradient(145deg, #3b82f6, #8b5cf6);
            color: white;
            text-decoration: none;
            padding: 12px 25px;
            border-radius: 30px;
            font-size: 0.95rem;
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .btn-view:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px -8px #3b82f6;
        }

        /* تصميم متجاوب */
        @media (max-width: 768px) {
            .edit-header {
                flex-direction: column;
                align-items: flex-start;
            }

            .form-actions {
                flex-direction: column;
            }

            .btn-delete {
                margin-right: 0;
            }

            .form-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <div class="background">
        <div class="gradient-orb"></div>
        <div class="gradient-orb-2"></div>
        <div class="particles"></div>
    </div>

    <div class="edit-container">
        <header class="edit-header">
            <a href="/admin" class="back-button">
                <i class="fas fa-arrow-right"></i>
                العودة للوحة التحكم
            </a>
            <h1>
                <i class="fas fa-edit"></i>
                تعديل البطاقة
            </h1>
            <span class="card-id-badge">
                <i class="fas fa-id-card"></i>
                <%= card.cardId %>
            </span>
        </header>

        <!-- رسائل النجاح والخطأ -->
        <% if (query && query.success) { %>
        <div class="alert success"><i class="fas fa-check-circle"></i> <%= query.success %></div>
        <% } %>
        <% if (query && query.error) { %>
        <div class="alert error"><i class="fas fa-exclamation-circle"></i> <%= query.error %></div>
        <% } %>

        <!-- نموذج تعديل البطاقة -->
        <div class="edit-section">
            <h2>
                <i class="fas fa-pencil-alt"></i>
                تعديل بيانات البطاقة
            </h2>

            <!-- ✅ التصحيح: النموذج يبدأ هنا ويحتوي على جميع الحقول -->
            <form action="/admin/card/update/<%= card.cardId %>" method="POST" class="edit-form" id="editForm">
                <!-- هذه حقول مخفية لتحديد طريقة PUT (بعض الخوادم تحتاجها) -->
                <input type="hidden" name="_method" value="PUT">
                
                <div class="form-grid">
                    <div class="form-group">
                        <label>معرف البطاقة (NFC ID):</label>
                        <input type="text" name="cardId" value="<%= card.cardId %>" readonly>
                    </div>
                    <div class="form-group">
                        <label>الاسم الكامل:</label>
                        <input type="text" name="name" value="<%= card.name %>" required>
                    </div>
                    <div class="form-group">
                        <label>المسمى الوظيفي:</label>
                        <input type="text" name="title" value="<%= card.title %>" required>
                    </div>
                    <div class="form-group">
                        <label>الشركة:</label>
                        <input type="text" name="company" value="<%= card.company || '' %>">
                    </div>
                    <div class="form-group">
                        <label>البريد الإلكتروني:</label>
                        <input type="email" name="email" value="<%= card.email || '' %>">
                    </div>
                    <div class="form-group">
                        <label>رقم الجوال:</label>
                        <input type="tel" name="phone" dir="ltr" value="<%= card.phone || '' %>">
                    </div>
                    <div class="form-group">
                        <label>الموقع الإلكتروني:</label>
                        <input type="url" name="website" dir="ltr" value="<%= card.website || '' %>">
                    </div>
                    <div class="form-group">
                        <label>العنوان:</label>
                        <input type="text" name="address" value="<%= card.address || '' %>">
                    </div>
                    <div class="form-group full-width">
                        <label>نبذة تعريفية:</label>
                        <textarea name="bio" rows="3"><%= card.bio || '' %></textarea>
                    </div>
                    <div class="form-group">
                        <label>LinkedIn:</label>
                        <input type="url" name="linkedin" dir="ltr" value="<%= card.linkedin || '' %>">
                    </div>
                    <div class="form-group">
                        <label>Twitter/X:</label>
                        <input type="url" name="twitter" dir="ltr" value="<%= card.twitter || '' %>">
                    </div>
                    <div class="form-group">
                        <label>GitHub:</label>
                        <input type="url" name="github" dir="ltr" value="<%= card.github || '' %>">
                    </div>
                    <div class="form-group full-width">
                        <label>رابط ديناميكي:</label>
                        <input type="url" name="dynamicLink" dir="ltr" placeholder="https://..." value="<%= card.dynamicLink || '' %>">
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn-save">
                        <i class="fas fa-save"></i>
                        حفظ التغييرات
                    </button>
                    <a href="/admin" class="btn-cancel">
                        <i class="fas fa-times"></i>
                        إلغاء
                    </a>
                    <!-- حذف البطاقة - يمكن أن يكون خارج النموذج أو داخله، لكن الأفضل أن يكون نموذج منفصل -->
                </div>
            </form>
            <!-- ✅ انتهى النموذج الصحيح هنا -->
            
            <!-- نموذج منفصل للحذف (خارج نموذج التحديث الرئيسي) -->
            <div style="margin-top: 20px;">
                <form action="/admin/card/delete/<%= card.cardId %>" method="POST" style="display:inline;" 
                      onsubmit="return confirm('هل أنت متأكد من حذف هذه البطاقة؟')">
                    <button type="submit" class="btn-delete">
                        <i class="fas fa-trash"></i>
                        حذف البطاقة
                    </button>
                </form>
            </div>
        </div>

        <!-- معاينة البطاقة -->
        <div class="edit-section preview-section">
            <h2>
                <i class="fas fa-eye"></i>
                معاينة البطاقة
            </h2>

            <div class="preview-toggle" onclick="togglePreview()">
                <i class="fas fa-chevron-down" id="previewIcon"></i>
                <span>عرض معاينة حية للبطاقة</span>
            </div>

            <div class="preview-card" id="previewCard">
                <div style="text-align: center; margin-bottom: 20px;">
                    <h3 id="previewName" style="color: #0f172a;"><%= card.name %></h3>
                    <p id="previewTitle" style="color: #3b82f6;"><%= card.title %> <%= card.company ? '- ' + card.company : '' %></p>
                </div>
                
                <div style="display: flex; flex-direction: column; gap: 10px;">
                    <% if (card.email) { %>
                    <p style="color: #64748b;"><i class="fas fa-envelope" style="color: #3b82f6; width: 25px;"></i> <%= card.email %></p>
                    <% } %>
                    <% if (card.phone) { %>
                    <p style="color: #64748b;"><i class="fas fa-phone" style="color: #3b82f6; width: 25px;"></i> <%= card.phone %></p>
                    <% } %>
                    <% if (card.website) { %>
                    <p style="color: #64748b;"><i class="fas fa-globe" style="color: #3b82f6; width: 25px;"></i> <%= card.website %></p>
                    <% } %>
                </div>

                <div style="margin-top: 20px; padding-top: 20px; border-top: 1px solid #e2e8f0;">
                    <a href="/card/<%= card.cardId %>" target="_blank" class="btn-view" style="display: inline-block;">
                        <i class="fas fa-external-link-alt"></i>
                        فتح البطاقة
                    </a>
                </div>
            </div>
        </div>
    </div>

    <script>
        // دالة إظهار/إخفاء المعاينة
        function togglePreview() {
            const preview = document.getElementById('previewCard');
            const icon = document.getElementById('previewIcon');
            
            preview.classList.toggle('show');
            
            if (preview.classList.contains('show')) {
                icon.classList.remove('fa-chevron-down');
                icon.classList.add('fa-chevron-up');
            } else {
                icon.classList.remove('fa-chevron-up');
                icon.classList.add('fa-chevron-down');
            }
        }

        // معاينة حية عند الكتابة
        document.addEventListener('DOMContentLoaded', function() {
            const nameInput = document.querySelector('input[name="name"]');
            const titleInput = document.querySelector('input[name="title"]');
            const companyInput = document.querySelector('input[name="company"]');
            
            const previewName = document.getElementById('previewName');
            const previewTitle = document.getElementById('previewTitle');
            
            if (nameInput) {
                nameInput.addEventListener('input', function() {
                    previewName.textContent = this.value || 'الاسم غير محدد';
                });
            }
            
            if (titleInput || companyInput) {
                const updateTitle = () => {
                    const title = titleInput ? titleInput.value : '';
                    const company = companyInput ? companyInput.value : '';
                    previewTitle.textContent = title + (company ? ' - ' + company : '');
                };
                
                if (titleInput) titleInput.addEventListener('input', updateTitle);
                if (companyInput) companyInput.addEventListener('input', updateTitle);
            }

            // تأثيرات تفاعلية
            const inputs = document.querySelectorAll('input, textarea, select');
            inputs.forEach(input => {
                input.addEventListener('focus', function() {
                    this.style.transform = 'scale(1.01)';
                });
                input.addEventListener('blur', function() {
                    this.style.transform = 'scale(1)';
                });
            });
        });
    </script>
</body>
</html>
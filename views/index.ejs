<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>NFC Pro  بطاقة ذكية </title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      background: #f4f9fe;  /* خلفية فاتحة جداً */
      color: #1e293b;
      min-height: 100vh;
      position: relative;
      overflow-x: hidden;
    }

    /* خلفية ناعمة متحركة – ألوان فاتحة */
    .background {
      position: fixed;
      width: 100vw;
      height: 100vh;
      top: 0;
      left: 0;
      z-index: -1;
      overflow: hidden;
    }

    .gradient-sphere {
      position: absolute;
      width: 80vw;
      height: 80vw;
      background: radial-gradient(circle at 30% 50%, rgba(147, 197, 253, 0.5) 0%, rgba(165, 180, 252, 0.35) 40%, transparent 70%);
      border-radius: 50%;
      top: -20%;
      right: -20%;
      animation: floatSphere 18s ease-in-out infinite;
    }

    .gradient-sphere-2 {
      position: absolute;
      width: 70vw;
      height: 70vw;
      background: radial-gradient(circle at 70% 50%, rgba(216, 180, 254, 0.45) 0%, rgba(187, 222, 252, 0.4) 50%, transparent 70%);
      border-radius: 50%;
      bottom: -20%;
      left: -20%;
      animation: floatSphere 22s ease-in-out infinite reverse;
    }

    @keyframes floatSphere {
      0%, 100% { transform: translate(0, 0) scale(1); }
      50% { transform: translate(-4%, 4%) scale(1.02); }
    }

    .particles {
      position: absolute;
      width: 100%;
      height: 100%;
      background-image: 
        radial-gradient(circle at 15% 25%, rgba(255, 255, 255, 0.5) 1.2px, transparent 1.2px),
        radial-gradient(circle at 75% 60%, rgba(255, 255, 255, 0.6) 1px, transparent 1px),
        radial-gradient(circle at 30% 80%, rgba(255, 255, 255, 0.5) 1.5px, transparent 1.5px),
        radial-gradient(circle at 85% 15%, rgba(255, 255, 255, 0.5) 1px, transparent 1px);
      background-size: 150px 150px;
      animation: moveParticles 35s linear infinite;
      opacity: 0.7;
    }

    @keyframes moveParticles {
      0% { background-position: 0 0, 0 0, 0 0, 0 0; }
      100% { background-position: 200px 200px, -150px 120px, 130px -180px, -100px -120px; }
    }

    .container {
      max-width: 1300px;
      margin: 0 auto;
      padding: 30px 40px;
      position: relative;
      z-index: 2;
    }

    /* هيدر بألوان فاتحة */
    header {
      text-align: center;
      margin-bottom: 60px;
      opacity: 0;
      animation: fadeInUp 0.9s cubic-bezier(0.2, 0.9, 0.3, 1) forwards;
    }

    @keyframes fadeInUp {
      0% { opacity: 0; transform: translateY(30px); }
      100% { opacity: 1; transform: translateY(0); }
    }

    h1 {
      font-size: 4rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      background: linear-gradient(145deg, #2563eb, #7c3aed, #38bdf8);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      margin-bottom: 12px;
      display: inline-flex;
      align-items: center;
      gap: 10px;
    }

    h1 i {
      font-size: 3.5rem;
      background: none;
      -webkit-text-fill-color: #3b82f6;
      filter: drop-shadow(0 4px 8px rgba(59,130,246,0.2));
      animation: softWiggle 5s infinite ease-in-out;
    }

    @keyframes softWiggle {
      0%,100% { transform: rotate(0deg); }
      25% { transform: rotate(6deg); }
      75% { transform: rotate(-4deg); }
    }

    .subtitle {
      font-size: 1.2rem;
      background: rgba(255,255,255,0.5);
      backdrop-filter: blur(8px);
      padding: 10px 30px;
      border-radius: 60px;
      display: inline-block;
      border: 1px solid rgba(255,255,255,0.6);
      box-shadow: 0 6px 18px rgba(0,20,50,0.05);
      color: #1e293b;
      font-weight: 500;
    }

    /* البطاقة الرئيسية - فاتحة جداً مع ظل خفيف */
    .hero {
      display: grid;
      grid-template-columns: 1.2fr 0.8fr;
      gap: 50px;
      margin-bottom: 80px;
      align-items: center;
    }

    .card-preview {
      perspective: 2000px;
    }

    .nfc-card {
      background: rgba(255, 255, 255, 0.7);
      backdrop-filter: blur(18px);
      border-radius: 48px;
      padding: 40px 30px;
      border: 1px solid rgba(255,255,255,0.7);
      box-shadow: 0 30px 50px -20px rgba(0,80,120,0.2), 0 0 0 1px rgba(255,255,255,0.8) inset;
      transform-style: preserve-3d;
      animation: cardHover 7s infinite alternate ease-in-out;
    }

    @keyframes cardHover {
      0% { transform: translateY(0) rotateX(1deg) rotateY(-1deg); }
      100% { transform: translateY(-12px) rotateX(2deg) rotateY(2deg); }
    }

    .card-header {
      display: flex;
      align-items: center;
      gap: 20px;
      margin-bottom: 25px;
      border-bottom: 1px solid rgba(0,0,0,0.05);
      padding-bottom: 20px;
    }

    .nfc-icon {
      font-size: 3.8rem;
      color: #3b82f6;
      filter: drop-shadow(0 6px 12px rgba(59,130,246,0.2));
      animation: iconFloat 4s infinite;
    }

    @keyframes iconFloat {
      0%,100% { transform: translateY(0); }
      50% { transform: translateY(-8px); }
    }

    .card-header h2 {
      font-size: 2.4rem;
      font-weight: 700;
      background: linear-gradient(120deg, #2563eb, #7c3aed);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .arabic {
      font-size: 2rem;
      font-weight: 600;
      color: #0f172a;
      margin-bottom: 15px;
    }

    .description {
      color: #334155;
      line-height: 1.6;
      font-size: 1.1rem;
      background: rgba(255,255,255,0.5);
      padding: 15px 20px;
      border-radius: 24px;
      border: 1px solid rgba(255,255,255,0.9);
    }

    .badge {
      background: linear-gradient(135deg, #3b82f6, #8b5cf6);
      color: white;
      padding: 14px 40px;
      border-radius: 40px;
      font-weight: 600;
      font-size: 1.15rem;
      border: none;
      cursor: pointer;
      display: inline-block;
      text-decoration: none;
      box-shadow: 0 12px 28px -8px #3b82f6;
      transition: all 0.25s ease;
      margin-top: 20px;
    }

    .badge:hover {
      transform: scale(1.02) translateY(-3px);
      box-shadow: 0 22px 35px -10px #3b82f6;
    }

    /* قسم المميزات - زجاجي فاتح */
    .features {
      background: rgba(255, 255, 255, 0.45);
      backdrop-filter: blur(15px);
      border-radius: 40px;
      padding: 35px 35px;
      border: 1px solid rgba(255,255,255,0.7);
      box-shadow: 0 20px 40px -15px rgba(0,40,80,0.1);
      animation: slideIn 0.8s 0.2s both;
    }

    @keyframes slideIn {
      from { opacity: 0; transform: translateX(40px); }
      to { opacity: 1; transform: translateX(0); }
    }

    .features h3 {
      font-size: 2rem;
      font-weight: 600;
      color: #0f172a;
      margin-bottom: 30px;
    }

    .features ul {
      list-style: none;
    }

    .features li {
      padding: 16px 0;
      font-size: 1.1rem;
      border-bottom: 1px solid rgba(0,0,0,0.05);
      display: flex;
      align-items: center;
      gap: 15px;
      opacity: 0;
      animation: listFade 0.4s forwards;
    }

    .features li:nth-child(1) { animation-delay: 0.2s; }
    .features li:nth-child(2) { animation-delay: 0.3s; }
    .features li:nth-child(3) { animation-delay: 0.4s; }
    .features li:nth-child(4) { animation-delay: 0.5s; }
    .features li:nth-child(5) { animation-delay: 0.6s; }

    @keyframes listFade {
      0% { opacity: 0; transform: translateX(-15px); }
      100% { opacity: 1; transform: translateX(0); }
    }

    .features li i {
      font-size: 1.7rem;
      background: linear-gradient(145deg, #3b82f6, #a78bfa);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    /* قسم الخطوات */
    .how-it-works {
      text-align: center;
      margin-bottom: 70px;
      opacity: 0;
      animation: fadeInUp 0.9s 0.4s forwards;
    }

    .how-it-works h3 {
      font-size: 2.4rem;
      font-weight: 600;
      color: #0f172a;
      margin-bottom: 40px;
    }

    .steps {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 30px;
    }

    .step {
      background: rgba(255, 255, 255, 0.5);
      backdrop-filter: blur(12px);
      border-radius: 36px;
      padding: 35px 25px;
      border: 1px solid rgba(255,255,255,0.7);
      transition: transform 0.3s, box-shadow 0.3s;
    }

    .step:hover {
      transform: translateY(-10px);
      background: rgba(255, 255, 255, 0.7);
      box-shadow: 0 22px 40px -20px #3b82f6;
    }

    .step-number {
      width: 70px;
      height: 70px;
      background: linear-gradient(145deg, #60a5fa, #c084fc);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 2rem;
      font-weight: 600;
      margin: 0 auto 22px;
      color: white;
      box-shadow: 0 8px 18px #b1d0fc;
    }

    .step h4 {
      font-size: 1.7rem;
      font-weight: 600;
      color: #1e293b;
      margin-bottom: 12px;
    }

    .step p {
      color: #334155;
    }

    /* زر العرض التجريبي */
    .demo-link {
      text-align: center;
      margin-bottom: 50px;
      opacity: 0;
      animation: fadeInUp 0.9s 0.6s forwards;
    }

    .demo-link h3 {
      font-size: 1.8rem;
      color: #1e293b;
      margin-bottom: 25px;
      font-weight: 500;
    }

    .demo-button {
      display: inline-flex;
      align-items: center;
      gap: 20px;
      padding: 18px 55px;
      background: rgba(255,255,255,0.5);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(255,255,255,0.7);
      border-radius: 50px;
      color: #1e293b;
      text-decoration: none;
      font-weight: 600;
      font-size: 1.25rem;
      transition: background 0.2s, border-color 0.2s;
      box-shadow: 0 6px 16px rgba(0,0,0,0.02);
    }

    .demo-button i {
      color: #3b82f6;
      font-size: 1.4rem;
    }

    .demo-button:hover {
      background: white;
      border-color: #a5b4fc;
      box-shadow: 0 16px 32px -12px #7c3aed;
    }

    /* footer خفيف */
    footer {
      text-align: center;
      padding: 20px;
      color: #5f6b7a;
      font-size: 0.95rem;
      border-top: 1px solid rgba(0,0,0,0.05);
      margin-top: 30px;
    }

    /* متجاوب */
    @media (max-width: 900px) {
      .hero { grid-template-columns: 1fr; }
      .steps { grid-template-columns: 1fr; }
      h1 { font-size: 3rem; }
    }

    /* تأثيرات إضافية ناعمة */
    .ripple-effect {
      position: absolute;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.6);
      transform: scale(0);
      animation: ripple 0.5s ease-out;
      pointer-events: none;
    }

    @keyframes ripple {
      to { transform: scale(6); opacity: 0; }
    }

    /* سكرول ناعم */
    ::-webkit-scrollbar { width: 10px; }
    ::-webkit-scrollbar-track { background: #e2e8f0; }
    ::-webkit-scrollbar-thumb { background: #b9d3f0; border-radius: 10px; }
  </style>
</head>
<body>
  <div class="background">
    <div class="gradient-sphere"></div>
    <div class="gradient-sphere-2"></div>
    <div class="particles"></div>
  </div>

  <div class="container">
    <header>
      <h1>
        <i class="fa-solid fa-wifi"></i> NFC Pro
      </h1>
      <p class="subtitle"><i class="fa-regular fa-circle-check" style="margin-left: 8px;"></i> بطاقة ذكية — انسَ التفاصيل، شارك بنقرة</p>
    </header>

    <div class="hero">
      <div class="card-preview">
        <div class="nfc-card">
          <div class="card-header">
            <span class="nfc-icon"><i class="fa-regular fa-id-card"></i></span>
            <h2>NFC Card</h2>
          </div>
          <div class="card-body">
            <p class="arabic"><i class="fa-regular fa-address-card" style="margin-left: 12px;"></i> بطاقة NFC ذكية</p>
            <p class="description">
              <i class="fa-solid fa-circle" style="font-size: 0.6rem; color: #3b82f6; margin-left: 6px;"></i>
              انقر مرة واحدة لفتح صفحتك المهنية — روابط ديناميكية، تحديثات لحظية.
            </p>
          </div>
          <div class="card-footer">
            <a href="create-profile" class="badge"><i class="fa-regular fa-hand-point-left" style="margin-left: 8px;"></i> طلب المنتج</a>
          </div>
        </div>
      </div>

      
    </div>

    

    <div class="demo-link">
      <h3><i class="fa-regular fa-eye" style="margin-left: 8px;"></i> جرب العرض التجريبي:</h3>
      <a href="/card/card-nfc-001" class="demo-button">
        <i class="fa-solid fa-play"></i> عرض بطاقة تجريبية <i class="fa-solid fa-arrow-left"></i>
      </a>
    </div>

  
  </div>

  <script>
    (function() {
      // تحريك بسيط وتأثيرات
      console.log('✨ NFC Pro • تصميم فاتح مع أنميشن');

      // بطاقة تتبع الماوس خفيفة
      const card = document.querySelector('.nfc-card');
      if (card) {
        card.addEventListener('mousemove', (e) => {
          const rect = card.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;
          const centerX = rect.width / 2;
          const centerY = rect.height / 2;
          const rotateX = (y - centerY) / 30;   // حركة ناعمة خفيفة
          const rotateY = (centerX - x) / 30;
          card.style.transition = 'transform 0.1s';
          card.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg)`;
        });
        card.addEventListener('mouseleave', () => {
          card.style.transition = 'transform 0.4s';
          card.style.transform = 'perspective(1000px) rotateX(0) rotateY(0)';
        });
      }

      // ripple effect على الأزرار
      const buttons = document.querySelectorAll('.badge, .demo-button');
      buttons.forEach(btn => {
        btn.addEventListener('click', function(e) {
          const ripple = document.createElement('span');
          ripple.className = 'ripple-effect';
          const rect = this.getBoundingClientRect();
          const size = Math.max(rect.width, rect.height);
          ripple.style.width = ripple.style.height = size + 'px';
          ripple.style.left = (e.clientX - rect.left - size/2) + 'px';
          ripple.style.top = (e.clientY - rect.top - size/2) + 'px';
          ripple.style.position = 'absolute';
          ripple.style.backgroundColor = 'rgba(255,255,255,0.6)';
          this.style.position = 'relative';
          this.appendChild(ripple);
          setTimeout(() => ripple.remove(), 500);
        });
      });

      // عنوان يظهر بحروف متحركة (اختياري)
      const h1 = document.querySelector('h1');
      if (h1) {
        const original = h1.innerText;
        // نتركه كما هو، لكننا نضيف sparkles
      }
    })();
  </script>

  <style>
    /* ضبط بعض الهوامش للايقونات */
    .fa-arrow-left, .fa-hand-point-left { transform: scaleX(-1); }
    .card-footer .badge i { margin-right: 4px; }
    .demo-button i.fa-arrow-left { margin-right: 5px; }
    .subtitle i { color: #3b82f6; }
  </style>
</body>
</html>
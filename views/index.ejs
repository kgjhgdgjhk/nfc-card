<!DOCTYPE html>
<html lang="ar" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>NFC Pro | بطاقات ذكية</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css"
    />
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: "Plus Jakarta Sans", sans-serif;
        background: #0a0a0f;
        color: #ffffff;
        min-height: 100vh;
        position: relative;
        overflow-x: hidden;
      }

      /* خلفية متحركة راقية */
      .background {
        position: fixed;
        width: 100vw;
        height: 100vh;
        top: 0;
        left: 0;
        z-index: -1;
        overflow: hidden;
      }

      .gradient-sphere {
        position: absolute;
        width: 80vw;
        height: 80vw;
        background: radial-gradient(
          circle at 30% 50%,
          rgba(76, 201, 240, 0.15) 0%,
          rgba(67, 97, 238, 0.15) 50%,
          transparent 70%
        );
        border-radius: 50%;
        top: -20%;
        right: -20%;
        animation: floatSphere 20s ease-in-out infinite;
      }

      .gradient-sphere-2 {
        position: absolute;
        width: 70vw;
        height: 70vw;
        background: radial-gradient(
          circle at 70% 50%,
          rgba(172, 107, 255, 0.12) 0%,
          rgba(76, 201, 240, 0.12) 50%,
          transparent 70%
        );
        border-radius: 50%;
        bottom: -20%;
        left: -20%;
        animation: floatSphere 25s ease-in-out infinite reverse;
      }

      @keyframes floatSphere {
        0%,
        100% {
          transform: translate(0, 0) scale(1);
        }
        50% {
          transform: translate(-5%, 5%) scale(1.05);
        }
      }

      /* جزيئات متحركة */
      .particles {
        position: absolute;
        width: 100%;
        height: 100%;
        background-image:
          radial-gradient(
            circle at 20% 30%,
            rgba(255, 255, 255, 0.05) 1px,
            transparent 1px
          ),
          radial-gradient(
            circle at 80% 70%,
            rgba(255, 255, 255, 0.05) 1px,
            transparent 1px
          ),
          radial-gradient(
            circle at 40% 80%,
            rgba(255, 255, 255, 0.05) 1px,
            transparent 1px
          ),
          radial-gradient(
            circle at 90% 20%,
            rgba(255, 255, 255, 0.05) 1px,
            transparent 1px
          );
        background-size: 200px 200px;
        animation: moveParticles 40s linear infinite;
      }

      @keyframes moveParticles {
        0% {
          background-position:
            0 0,
            0 0,
            0 0,
            0 0;
        }
        100% {
          background-position:
            200px 200px,
            -200px 100px,
            100px -200px,
            -100px -100px;
        }
      }

      .container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 40px 60px;
        position: relative;
        z-index: 1;
      }

      /* الهيدر بتصميم أنيق */
      header {
        text-align: center;
        margin-bottom: 80px;
        opacity: 0;
        animation: fadeInUp 1s ease-out forwards;
      }

      @keyframes fadeInUp {
        from {
          opacity: 0;
          transform: translateY(40px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      h1 {
        font-size: 4.5em;
        font-weight: 800;
        letter-spacing: -0.02em;
        background: linear-gradient(135deg, #fff 0%, #a5b4fc 50%, #818cf8 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        margin-bottom: 20px;
        position: relative;
        display: inline-block;
      }

      h1::after {
        content: "";
        position: absolute;
        bottom: -10px;
        left: 50%;
        transform: translateX(-50%);
        width: 100px;
        height: 4px;
        background: linear-gradient(
          90deg,
          transparent,
          #4cc9f0,
          #4361ee,
          #4cc9f0,
          transparent
        );
        border-radius: 2px;
        animation: lineGlow 3s ease-in-out infinite;
      }

      @keyframes lineGlow {
        0%,
        100% {
          opacity: 0.5;
          width: 100px;
        }
        50% {
          opacity: 1;
          width: 150px;
        }
      }

      .subtitle {
        font-size: 1.2em;
        color: rgba(255, 255, 255, 0.7);
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(10px);
        padding: 12px 32px;
        border-radius: 100px;
        display: inline-block;
        border: 1px solid rgba(255, 255, 255, 0.05);
        box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.5);
      }

      /* القسم الرئيسي */
      .hero {
        display: grid;
        grid-template-columns: 1.2fr 0.8fr;
        gap: 60px;
        margin-bottom: 100px;
        align-items: center;
      }

      /* تصميم البطاقة العصري */
      .card-preview {
        perspective: 2000px;
      }

      .nfc-card {
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(20px);
        border-radius: 40px;
        padding: 40px;
        border: 1px solid rgba(255, 255, 255, 0.05);
        box-shadow:
          0 25px 50px -12px rgba(0, 0, 0, 0.5),
          0 0 0 1px rgba(255, 255, 255, 0.02) inset;
        transform-style: preserve-3d;
        animation: cardFloat 6s ease-in-out infinite;
        position: relative;
        overflow: hidden;
      }

      .nfc-card::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: radial-gradient(
          circle at 30% 50%,
          rgba(255, 255, 255, 0.1) 0%,
          transparent 50%
        );
        pointer-events: none;
      }

      @keyframes cardFloat {
        0%,
        100% {
          transform: translateY(0) rotateX(0deg) rotateY(0deg);
        }
        25% {
          transform: translateY(-15px) rotateX(2deg) rotateY(2deg);
        }
        50% {
          transform: translateY(0) rotateX(0deg) rotateY(0deg);
        }
        75% {
          transform: translateY(-15px) rotateX(-2deg) rotateY(-2deg);
        }
      }

      .card-header {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 30px;
        padding-bottom: 20px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
      }

      .nfc-icon {
        font-size: 3.5em;
        filter: drop-shadow(0 0 20px rgba(76, 201, 240, 0.5));
        animation: iconPulse 3s ease-in-out infinite;
      }

      @keyframes iconPulse {
        0%,
        100% {
          filter: drop-shadow(0 0 20px rgba(76, 201, 240, 0.5));
          transform: scale(1);
        }
        50% {
          filter: drop-shadow(0 0 30px rgba(67, 97, 238, 0.8));
          transform: scale(1.05);
        }
      }

      .card-header h2 {
        font-size: 2.2em;
        font-weight: 700;
        background: linear-gradient(135deg, #fff, #a5b4fc);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
      }

      .card-body {
        margin-bottom: 30px;
      }

      .arabic {
        font-size: 2em;
        font-weight: 700;
        margin-bottom: 15px;
        color: #fff;
      }

      .description {
        color: rgba(255, 255, 255, 0.7);
        line-height: 1.7;
        font-size: 1.1em;
      }

      /* زر متطور */
      .badge {
        background: linear-gradient(135deg, #4361ee, #4cc9f0);
        color: white;
        padding: 16px 48px;
        border-radius: 16px;
        font-weight: 600;
        font-size: 1.1em;
        border: none;
        cursor: pointer;
        position: relative;
        overflow: hidden;
        transition: all 0.3s ease;
        display: inline-block;
        text-decoration: none;
        letter-spacing: 0.5px;
        box-shadow: 0 10px 30px -10px #4361ee;
      }

      .badge::before {
        content: "";
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(
          90deg,
          transparent,
          rgba(255, 255, 255, 0.2),
          transparent
        );
        transition: left 0.5s ease;
      }

      .badge:hover {
        transform: translateY(-3px);
        box-shadow: 0 20px 40px -10px #4361ee;
      }

      .badge:hover::before {
        left: 100%;
      }

      /* قسم المميزات */
      .features {
        background: rgba(255, 255, 255, 0.02);
        backdrop-filter: blur(10px);
        border-radius: 40px;
        padding: 40px;
        border: 1px solid rgba(255, 255, 255, 0.05);
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        animation: slideIn 1s ease-out 0.3s both;
      }

      @keyframes slideIn {
        from {
          opacity: 0;
          transform: translateX(50px);
        }
        to {
          opacity: 1;
          transform: translateX(0);
        }
      }

      .features h3 {
        font-size: 2em;
        font-weight: 700;
        margin-bottom: 30px;
        background: linear-gradient(135deg, #fff, #a5b4fc);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
      }

      .features ul {
        list-style: none;
      }

      .features li {
        padding: 18px 0;
        font-size: 1.1em;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        display: flex;
        align-items: center;
        gap: 15px;
        opacity: 0;
        animation: fadeInList 0.5s ease-out forwards;
      }

      .features li:nth-child(1) {
        animation-delay: 0.4s;
      }
      .features li:nth-child(2) {
        animation-delay: 0.5s;
      }
      .features li:nth-child(3) {
        animation-delay: 0.6s;
      }
      .features li:nth-child(4) {
        animation-delay: 0.7s;
      }
      .features li:nth-child(5) {
        animation-delay: 0.8s;
      }

      @keyframes fadeInList {
        to {
          opacity: 1;
          transform: translateX(0);
        }
        from {
          opacity: 0;
          transform: translateX(-20px);
        }
      }

      .features li i {
        font-size: 1.5em;
        background: linear-gradient(135deg, #4361ee, #4cc9f0);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
      }

      /* قسم الخطوات */
      .how-it-works {
        text-align: center;
        margin-bottom: 80px;
        opacity: 0;
        animation: fadeInUp 1s ease-out 0.6s forwards;
      }

      .how-it-works h3 {
        font-size: 2.5em;
        font-weight: 700;
        margin-bottom: 50px;
        background: linear-gradient(135deg, #fff, #a5b4fc);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
      }

      .steps {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 30px;
      }

      .step {
        background: rgba(255, 255, 255, 0.02);
        backdrop-filter: blur(10px);
        border-radius: 30px;
        padding: 40px 30px;
        border: 1px solid rgba(255, 255, 255, 0.05);
        transition: all 0.4s ease;
        position: relative;
        overflow: hidden;
      }

      .step::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 2px;
        background: linear-gradient(
          90deg,
          transparent,
          #4361ee,
          #4cc9f0,
          #4361ee,
          transparent
        );
        transform: translateX(-100%);
        transition: transform 0.6s ease;
      }

      .step:hover::before {
        transform: translateX(100%);
      }

      .step:hover {
        transform: translateY(-10px);
        box-shadow: 0 20px 40px -10px rgba(67, 97, 238, 0.3);
      }

      .step-number {
        width: 70px;
        height: 70px;
        background: linear-gradient(135deg, #4361ee, #4cc9f0);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8em;
        font-weight: 700;
        margin: 0 auto 25px;
        color: white;
        box-shadow: 0 10px 30px -5px #4361ee;
      }

      .step h4 {
        font-size: 1.5em;
        margin-bottom: 15px;
        color: #fff;
      }

      .step p {
        color: rgba(255, 255, 255, 0.6);
        line-height: 1.6;
      }

      /* قسم العرض التجريبي */
      .demo-link {
        text-align: center;
        margin-bottom: 60px;
        opacity: 0;
        animation: fadeInUp 1s ease-out 0.9s forwards;
      }

      .demo-link h3 {
        font-size: 2em;
        margin-bottom: 30px;
        color: rgba(255, 255, 255, 0.8);
      }

      .demo-button {
        display: inline-flex;
        align-items: center;
        gap: 15px;
        padding: 18px 50px;
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 20px;
        color: white;
        text-decoration: none;
        font-weight: 600;
        font-size: 1.2em;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
      }

      .demo-button::before {
        content: "";
        position: absolute;
        top: 50%;
        left: 50%;
        width: 0;
        height: 0;
        border-radius: 50%;
        background: rgba(67, 97, 238, 0.3);
        transform: translate(-50%, -50%);
        transition:
          width 0.6s ease,
          height 0.6s ease;
      }

      .demo-button:hover::before {
        width: 300px;
        height: 300px;
      }

      .demo-button i {
        font-size: 1.3em;
        color: #4cc9f0;
        transition: transform 0.3s ease;
      }

      .demo-button:hover i {
        transform: translateX(-5px) rotate(5deg);
      }

      .demo-button:hover {
        border-color: #4361ee;
        box-shadow: 0 10px 30px -5px #4361ee;
      }

      /* فوتر */
      footer {
        text-align: center;
        padding: 30px;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
        color: rgba(255, 255, 255, 0.5);
        font-size: 0.95em;
        opacity: 0;
        animation: fadeIn 1s ease-out 1.2s forwards;
      }

      @keyframes fadeIn {
        to {
          opacity: 1;
        }
      }

      /* تصميم متجاوب */
      @media (max-width: 1024px) {
        .container {
          padding: 40px 30px;
        }

        h1 {
          font-size: 3.5em;
        }

        .hero {
          grid-template-columns: 1fr;
          gap: 40px;
        }
      }

      @media (max-width: 768px) {
        h1 {
          font-size: 2.5em;
        }

        .steps {
          grid-template-columns: 1fr;
        }

        .hero {
          grid-template-columns: 1fr;
        }

        .container {
          padding: 30px 20px;
        }
      }

      /* تأثيرات إضافية */
      .glow-text {
        text-shadow: 0 0 30px rgba(67, 97, 238, 0.5);
      }

      .hover-glow {
        transition: all 0.3s ease;
      }

      .hover-glow:hover {
        box-shadow: 0 0 30px rgba(76, 201, 240, 0.3);
      }
    </style>
  </head>
  <body>
    <div class="background">
      <div class="gradient-sphere"></div>
      <div class="gradient-sphere-2"></div>
      <div class="particles"></div>
    </div>

    <div class="container">
      <header>
        <h1>
          <i class="fas fa-wifi" style="margin-left: 15px"></i>
          NFC Pro
        </h1>
        <p class="subtitle">
          <i class="fas fa-bolt" style="margin-left: 8px"></i>
          بطاقة ذكية - انقر مرة واحدة لفتح صفحتك المهنية
        </p>
      </header>

      <main>
        <div class="hero">
          <div class="card-preview">
            <div class="nfc-card">
              <div class="card-header">
                <span class="nfc-icon">
                  <i class="fas fa-id-card"></i>
                </span>
                <h2>NFC Card</h2>
              </div>
              <div class="card-body">
                <p class="arabic">
                  <i class="fas fa-id-card" style="margin-left: 10px"></i>
                  بطاقة NFC ذكية
                </p>
                <p class="description">
                  <i
                    class="fas fa-circle"
                    style="
                      font-size: 0.5em;
                      vertical-align: middle;
                      margin-left: 5px;
                      color: #4cc9f0;
                    "
                  ></i>
                  انقر مرة واحدة لفتح صفحتك المهنية — تدعم روابط ديناميكية
                  وتحديثات لحظية
                </p>
              </div>
              <div class="card-footer">
                <a href="/create-profile" class="badge">
                  <i class="fas fa-arrow-left" style="margin-left: 8px"></i>
                  طلب المنتج
                </a>
              </div>
            </div>
          </div>

          <div class="features">
            <h3>
              <i class="fas fa-sparkles" style="margin-left: 10px"></i>
              مميزات النظام
            </h3>
            <ul>
              <li>
                <i class="fas fa-link"></i>
                روابط ديناميكية قابلة للتحديث
              </li>
              <li>
                <i class="fas fa-chart-line"></i>
                إحصائيات الزيارات لحظياً
              </li>
              <li>
                <i class="fas fa-sync-alt"></i>
                تحديث البيانات بدون تغيير البطاقة
              </li>
              <li>
                <i class="fas fa-mobile-alt"></i>
                صفحة مهنية متكاملة
              </li>
              <li>
                <i class="fas fa-share-alt"></i>
                روابط التواصل الاجتماعي
              </li>
            </ul>
          </div>
        </div>

        <div class="how-it-works">
          <h3>
            <i class="fas fa-magic" style="margin-left: 10px"></i>
            كيف يعمل النظام؟
          </h3>
          <div class="steps">
            <div class="step">
              <div class="step-number">1</div>
              <h4>مسح البطاقة</h4>
              <p>قم بتقريب هاتفك من بطاقة NFC</p>
            </div>
            <div class="step">
              <div class="step-number">2</div>
              <h4>فتح الرابط</h4>
              <p>يتم فتح صفحتك المهنية تلقائياً</p>
            </div>
            <div class="step">
              <div class="step-number">3</div>
              <h4>عرض المعلومات</h4>
              <p>تظهر جميع بياناتك المهنية</p>
            </div>
          </div>
        </div>

        <div class="demo-link">
          <h3>جرب العرض التجريبي:</h3>
          <a href="/card/card-nfc-001" class="demo-button">
            <i class="fas fa-play"></i>
            عرض بطاقة تجريبية
            <i class="fas fa-arrow-left"></i>
          </a>
        </div>
      </main>

      <footer></footer>
    </div>

    <script>
      // تأثيرات تفاعلية متطورة
      document.addEventListener("DOMContentLoaded", function () {
        // رسالة ترحيبية
        console.log(
          "%c✨ NFC Pro - النظام الذكي للبطاقات",
          "color: #4cc9f0; font-size: 14px; font-weight: bold;",
        );

        // تأثير تحميل متتابع
        const elements = document.querySelectorAll(".step, .feature-item");
        elements.forEach((el, index) => {
          el.style.animationDelay = `${index * 0.1 + 0.5}s`;
        });

        // تأثير حركة الماوس على البطاقة
        const card = document.querySelector(".nfc-card");
        if (card) {
          card.addEventListener("mousemove", (e) => {
            const rect = card.getBoundingClientRect();
            const x = e.clientX - rect.left;
            const y = e.clientY - rect.top;

            const centerX = rect.width / 2;
            const centerY = rect.height / 2;

            const rotateX = (y - centerY) / 20;
            const rotateY = (centerX - x) / 20;

            card.style.transform = `perspective(2000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) translateY(-10px)`;
          });

          card.addEventListener("mouseleave", () => {
            card.style.transform =
              "perspective(2000px) rotateX(0) rotateY(0) translateY(0)";
          });
        }

        // تأثير ظهور العناصر عند التمرير
        const observerOptions = {
          threshold: 0.1,
          rootMargin: "0px 0px -50px 0px",
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.style.opacity = "1";
              entry.target.style.transform = "translateY(0)";
            }
          });
        }, observerOptions);

        document
          .querySelectorAll(".step, .features, .demo-link")
          .forEach((el) => {
            el.style.opacity = "0";
            el.style.transform = "translateY(30px)";
            el.style.transition = "all 0.6s ease-out";
            observer.observe(el);
          });
      });

      // تأثير الكتابة التلقائية للعنوان
      const title = document.querySelector("h1");
      if (title) {
        const originalText = title.innerText;
        title.innerText = "";
        let i = 0;

        function typeWriter() {
          if (i < originalText.length) {
            title.innerHTML += originalText.charAt(i);
            i++;
            setTimeout(typeWriter, 100);
          }
        }

        // تشغيل التأثير بعد ثانية
        setTimeout(typeWriter, 500);
      }
    </script>

    <style>
      /* إضافة تأثيرات CSS إضافية */
      .ripple-effect {
        position: absolute;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.4);
        transform: scale(0);
        animation: ripple-animation 0.6s ease-out;
        pointer-events: none;
      }

      @keyframes ripple-animation {
        to {
          transform: scale(4);
          opacity: 0;
        }
      }

      /* تخصيص شريط التمرير */
      ::-webkit-scrollbar {
        width: 10px;
      }

      ::-webkit-scrollbar-track {
        background: #0a0a0f;
      }

      ::-webkit-scrollbar-thumb {
        background: linear-gradient(135deg, #4361ee, #4cc9f0);
        border-radius: 5px;
      }

      ::-webkit-scrollbar-thumb:hover {
        background: linear-gradient(135deg, #4cc9f0, #4361ee);
      }

      /* تحديد النص */
      ::selection {
        background: #4361ee;
        color: white;
      }
    </style>
  </body>
</html>

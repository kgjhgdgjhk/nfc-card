<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>طلب بطاقة NFC ذكية</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        .order-page {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            padding: 20px;
        }
        
        .order-container {
            max-width: 800px;
            width: 100%;
            background: white;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            animation: slideIn 0.5s ease;
        }
        
        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        .order-header {
            background: linear-gradient(135deg, #2c3e50, #3498db);
            color: white;
            padding: 40px;
            text-align: center;
        }
        
        .order-header h1 {
            font-size: 2.5em;
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }
        
        .order-header i {
            font-size: 1.5em;
            animation: pulse 2s infinite;
        }
        
        @keyframes pulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.1); }
        }
        
        .order-content {
            padding: 40px;
            text-align: center;
        }
        
        .thank-you-message {
            font-size: 1.5em;
            color: #2c3e50;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 15px;
        }
        
        .redirect-message {
            color: #666;
            font-size: 1.2em;
            margin-bottom: 30px;
        }
        
        .nfc-icon-large {
            font-size: 4em;
            color: #3498db;
            margin: 20px 0;
            animation: bounce 2s infinite;
        }
        
        @keyframes bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }
        
        .progress-bar {
            width: 100%;
            height: 4px;
            background: #ecf0f1;
            border-radius: 2px;
            margin: 30px 0;
            overflow: hidden;
            position: relative;
        }
        
        .progress-fill {
            position: absolute;
            top: 0;
            left: 0;
            height: 100%;
            background: linear-gradient(90deg, #3498db, #2ecc71);
            width: 0%;
            animation: progress 3s ease forwards;
        }
        
        @keyframes progress {
            to {
                width: 100%;
            }
        }
        
        .order-details {
            background: #f8f9fa;
            border-radius: 15px;
            padding: 30px;
            margin: 30px 0;
            text-align: right;
        }
        
        .order-details h3 {
            color: #2c3e50;
            margin-bottom: 20px;
            font-size: 1.3em;
        }
        
        .detail-item {
            display: flex;
            align-items: center;
            gap: 15px;
            padding: 15px;
            border-bottom: 1px solid #dee2e6;
            transition: background 0.3s ease;
        }
        
        .detail-item:hover {
            background: white;
        }
        
        .detail-item i {
            width: 30px;
            color: #3498db;
            font-size: 1.2em;
        }
        
        .detail-item .label {
            font-weight: bold;
            color: #2c3e50;
            min-width: 120px;
        }
        
        .detail-item .value {
            color: #666;
        }
        
        .whatsapp-button {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            background: #25d366;
            color: white;
            padding: 15px 40px;
            border-radius: 50px;
            text-decoration: none;
            font-size: 1.2em;
            margin: 20px 0;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            border: none;
            cursor: pointer;
        }
        
        .whatsapp-button:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(37, 211, 102, 0.3);
        }
        
        .home-button {
            display: inline-block;
            background: #2c3e50;
            color: white;
            padding: 12px 30px;
            border-radius: 50px;
            text-decoration: none;
            margin-top: 20px;
            transition: background 0.3s ease;
        }
        
        .home-button:hover {
            background: #34495e;
        }
        
        .countdown {
            font-size: 1.1em;
            color: #e74c3c;
            margin: 20px 0;
        }
        
        .order-footer {
            background: #f8f9fa;
            padding: 20px;
            text-align: center;
            color: #666;
            border-top: 1px solid #dee2e6;
        }
    </style>
</head>
<body>
    <div class="order-page">
        <div class="order-container">
            <div class="order-header">
                <h1>
                    <i class="fas fa-shopping-cart"></i>
                    طلب بطاقة NFC ذكية
                </h1>
                <p>شكراً لاهتمامك بمنتجاتنا المبتكرة</p>
            </div>
            
            <div class="order-content">
                <div class="thank-you-message">
                    <i class="fas fa-check-circle" style="color: #27ae60;"></i>
                    <span>تم استلام طلبك بنجاح!</span>
                </div>
                
                <div class="nfc-icon-large">
                    <i class="fas fa-wifi"></i>
                </div>
                
                <p class="redirect-message">سيتم تحويلك الآن إلى واتساب للتواصل مع فريق المبيعات...</p>
                
                <div class="progress-bar">
                    <div class="progress-fill"></div>
                </div>
                
                <div class="countdown" id="countdown">
                    سيتم التحويل خلال 3 ثواني...
                </div>
                
                <div class="order-details">
                    <h3>📋 تفاصيل الطلب المبدئي:</h3>
                    
                    <div class="detail-item">
                        <i class="fas fa-id-card"></i>
                        <span class="label">المنتج:</span>
                        <span class="value">بطاقة NFC ذكية قابلة للبرمجة</span>
                    </div>
                    
                    <div class="detail-item">
                        <i class="fas fa-microchip"></i>
                        <span class="label">النوع:</span>
                        <span class="value">NFC NTAG 215 - 504 بايت</span>
                    </div>
                    
                    <div class="detail-item">
                        <i class="fas fa-palette"></i>
                        <span class="label">التصميم:</span>
                        <span class="value">تصميم مخصص حسب الطلب</span>
                    </div>
                    
                    <div class="detail-item">
                        <i class="fas fa-rocket"></i>
                        <span class="label">المميزات:</span>
                        <span class="value">روابط ديناميكية + تحديث لحظي + إحصائيات</span>
                    </div>
                    
                    <div class="detail-item">
                        <i class="fas fa-clock"></i>
                        <span class="label">مدة التوصيل:</span>
                        <span class="value">3-5 أيام عمل</span>
                    </div>
                </div>
                
                <!-- زر واتساب المباشر -->
                <a href="https://wa.me/966500000000?text=السلام%20عليكم%2C%20أرغب%20في%20طلب%20بطاقة%20NFC%20ذكية" 
                   target="_blank" 
                   class="whatsapp-button" 
                   id="whatsappButton">
                    <i class="fab fa-whatsapp"></i>
                    تواصل معنا عبر واتساب
                </a>
                
                <br>
                
                <a href="/" class="home-button">
                    <i class="fas fa-home"></i>
                    العودة للصفحة الرئيسية
                </a>
            </div>
            
            <div class="order-footer">
                <p>© 2024 جميع الحقوق محفوظة - نظام بطاقات NFC الذكية</p>
            </div>
        </div>
    </div>

    <script>
        // عداد تنازلي للتحويل إلى واتساب
        let seconds = 3;
        const countdownElement = document.getElementById('countdown');
        const whatsappButton = document.getElementById('whatsappButton');
        
        // رقم واتساب الافتراضي (يمكن تغييره)
        const whatsappNumber = '966500000000'; // ضع رقم واتساب هنا
        const message = encodeURIComponent('السلام عليكم، أرغب في طلب بطاقة NFC ذكية');
        
        function updateCountdown() {
            countdownElement.textContent = `سيتم التحويل خلال ${seconds} ثانية...`;
            
            if (seconds <= 0) {
                // فتح واتساب تلقائياً
                window.location.href = `https://wa.me/${whatsappNumber}?text=${message}`;
            } else {
                seconds--;
                setTimeout(updateCountdown, 1000);
            }
        }
        
        // بدء العد التنازلي بعد 1 ثانية
        setTimeout(updateCountdown, 1000);
        
        // تحديث رابط واتساب ليشمل الرسالة
        whatsappButton.href = `https://wa.me/${whatsappNumber}?text=${message}`;
        
        // تسجيل الصفحة في console
        console.log('تم فتح صفحة طلب المنتج - سيتم التحويل إلى واتساب');
        
        // تأثيرات بصرية إضافية
        document.querySelectorAll('.detail-item').forEach((item, index) => {
            item.style.animation = `fadeInUp 0.5s ease ${index * 0.1}s forwards`;
            item.style.opacity = '0';
        });
        
        // إضافة CSS للحركة
        const style = document.createElement('style');
        style.textContent = `
            @keyframes fadeInUp {
                from {
                    opacity: 0;
                    transform: translateY(20px);
                }
                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }
        `;
        document.head.appendChild(style);
    </script>
</body>
</html>
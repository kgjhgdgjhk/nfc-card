<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>بطاقة العمل الذكية - <%= template === 'classic' ? 'كلاسيكي' : template === 'modern' ? 'عصري' : template === 'minimal' ? 'بسيط' : template === 'dark' ? 'داكن' : template === 'tech' ? 'تقني' : template === 'elegant' ? 'أنيق' : template === 'corporate' ? 'مؤسسي' : template === 'creative' ? 'إبداعي' : template === '3d' ? 'ثلاثي الأبعاد' : template === 'neon' ? 'نيون' : 'مميز' %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: linear-gradient(145deg, #d0d9e0 0%, #eef2f7 100%);
            font-family: 'Plus Jakarta Sans', sans-serif;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 30px;
        }

        .cards-wrapper {
            display: flex;
            flex-direction: column;
            gap: 40px;
            max-width: 1200px;
        }

        /* البطاقة الأساسية */
        .business-card {
            width: 750px;
            height: 420px;
            position: relative;
            overflow: hidden;
            border-radius: 28px;
            background: #ffffff;
            box-shadow: 0 30px 50px -15px rgba(0, 50, 80, 0.4);
            border: 1px solid rgba(255, 255, 255, 0.5);
        }

        /* الجهة الملونة (الخلفية) */
        .card-panel {
            position: absolute;
            top: 0;
            width: 45%;
            height: 100%;
            padding: 35px 25px;
            z-index: 5;
            display: flex;
            flex-direction: column;
            justify-content: center;
            box-sizing: border-box;
        }

        /* الجهة المقابلة (النصية) */
        .card-panel-text {
            position: absolute;
            top: 0;
            width: 55%;
            height: 100%;
            padding: 30px 25px;
            z-index: 5;
            display: flex;
            flex-direction: column;
            justify-content: center;
            background: transparent;
            box-sizing: border-box;
        }

        /* تحديد مواقع البانيلات حسب البطاقة */
        .card-primary .panel-colored {
            left: 0;
            color: white;
        }

        .card-primary .panel-text {
            right: 0;
        }

        .card-secondary .panel-colored {
            right: 0;
            color: white;
        }

        .card-secondary .panel-text {
            left: 0;
        }

        /* أنماط القوالب المختلفة */
        
        /* 1. القالب العصري - modern */
        .template-modern .card-primary .panel-colored,
        .template-modern .card-secondary .panel-colored {
            background: linear-gradient(135deg, #667eea, #764ba2, #3b82f6);
            background-size: 200% 200%;
            animation: gradientShift 8s ease infinite;
        }
        
        /* 2. القالب الكلاسيكي - classic */
        .template-classic .card-primary .panel-colored,
        .template-classic .card-secondary .panel-colored {
            background: linear-gradient(145deg, #2d3748, #1e293b);
        }
        
        /* 3. القالب البسيط - minimal */
        .template-minimal .card-primary .panel-colored,
        .template-minimal .card-secondary .panel-colored {
            background: #f8fafc;
            color: #0f172a;
            border-left: 4px solid #94a3b8;
        }
        
        /* 4. القالب الداكن - dark */
        .template-dark .card-primary .panel-colored,
        .template-dark .card-secondary .panel-colored {
            background: #0f172a;
        }
        
        /* 5. القالب التقني - tech */
        .template-tech .card-primary .panel-colored,
        .template-tech .card-secondary .panel-colored {
            background: linear-gradient(145deg, #0f2027, #203a43, #2c5364);
        }
        
        /* 6. القالب الأنيق - elegant */
        .template-elegant .card-primary .panel-colored,
        .template-elegant .card-secondary .panel-colored {
            background: linear-gradient(145deg, #42275a, #734b6d);
        }
        
        /* 7. القالب المؤسسي - corporate */
        .template-corporate .card-primary .panel-colored,
        .template-corporate .card-secondary .panel-colored {
            background: linear-gradient(145deg, #1e3c72, #2a5298);
        }
        
        /* 8. القالب الإبداعي - creative */
        .template-creative .card-primary .panel-colored,
        .template-creative .card-secondary .panel-colored {
            background: linear-gradient(145deg, #f12711, #f5af19);
        }
        
        /* 9. القالب ثلاثي الأبعاد - 3d */
        .template-3d .card-primary .panel-colored,
        .template-3d .card-secondary .panel-colored {
            background: linear-gradient(145deg, #0b0c10, #1f2833, #0b0c10);
        }
        
        /* 10. القالب النيون - neon */
        .template-neon .card-primary .panel-colored,
        .template-neon .card-secondary .panel-colored {
            background: linear-gradient(145deg, #0f0c29, #302b63, #24243e);
        }

        @keyframes gradientShift {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        /* الموجة الزخرفية */
        .wave-divider {
            position: absolute;
            top: 0;
            width: 130px;
            height: 100%;
            z-index: 10;
            pointer-events: none;
        }

        .card-primary .wave-divider {
            left: 42%;
            transform: translateX(-50%) scaleX(1);
        }

        .card-secondary .wave-divider {
            right: 42%;
            transform: translateX(50%) scaleX(-1);
        }

        .wave-divider svg {
            width: 100%;
            height: 100%;
            fill: #ffffff;
        }

        /* المحتوى داخل البانل الملون */
        .brand-content {
            width: 100%;
        }

        .job-title-display {
            font-size: 32px;
            font-weight: 800;
            margin-bottom: 6px;
            line-height: 1.2;
        }

        .company-name-display {
            font-size: 20px;
            opacity: 0.85;
            font-weight: 500;
            letter-spacing: 1px;
        }

        /* المحتوى داخل البانل النصي */
        .info-content {
            width: 100%;
        }

        .personal-name {
            font-size: 36px;
            font-weight: 900;
            margin-bottom: 5px;
            line-height: 1.1;
        }

        /* توزيع بيانات الاتصال في عمودين */
        .contact-details {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px 10px;
            margin-bottom: 15px;
        }

        .detail-item {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 18px;
            background: rgba(0, 100, 180, 0.03);
            padding: 12px 15px;
            border-radius: 50px;
            border: 1px solid rgba(0, 140, 255, 0.08);
            white-space: nowrap;
            overflow: hidden;
            width: 100%;
            min-width: 0;
        }

        .detail-item i {
            width: 24px;
            font-size: 20px;
            flex-shrink: 0;
        }

        .detail-item span {
            font-weight: 500;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            flex: 1;
            min-width: 0;
        }

        /* القسم السفلي للكرت الثاني */
        .social-qr-section {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            width: 100%;
        }

        .social-links {
            display: flex;
            gap: 30px;
            margin-bottom: 20px;
        }

        .social-links i {
            font-size: 30px;
            background: #f0f5fd;
            padding: 10px;
            border-radius: 50%;
            transition: 0.2s;
            cursor: pointer;
        }

        .social-links i:hover {
            background: #d4e4ff;
            transform: scale(1.1);
        }

        .qr-code {
            width: 110px;
            height: 110px;
            border-radius: 18px;
            margin-bottom: 12px;
            border: 2px solid #1e2f3f;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

        .qr-code img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .scan-code-text {
            font-size: 15px;
            font-weight: 600;
            color: #1f4970;
            letter-spacing: 1px;
            cursor: pointer;
        }

        /* رابط البطاقة */
        .profile-link {
            margin-top: 20px;
            font-size: 12px;
            direction: ltr;
            text-align: left;
            background: rgba(255,255,255,0.7);
            padding: 8px 12px;
            border-radius: 30px;
            border: 1px solid #e2e8f0;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .profile-link span {
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            max-width: 250px;
        }

        .copy-link-btn {
            background: none;
            border: none;
            color: #0077be;
            cursor: pointer;
            font-size: 14px;
            padding: 0 5px;
            flex-shrink: 0;
        }

        /* ========== أنماط ألوان القوالب الكاملة ========== */

        /* لون النص في المنطقة النصية حسب القالب */
        .template-modern .panel-text,
        .template-modern .personal-name,
        .template-modern .detail-item span,
        .template-modern .profile-link span {
            color: #1e293b;
        }

        .template-classic .panel-text,
        .template-classic .personal-name,
        .template-classic .detail-item span,
        .template-classic .profile-link span {
            color: #1e293b;
        }

        .template-minimal .panel-text,
        .template-minimal .personal-name,
        .template-minimal .detail-item span,
        .template-minimal .profile-link span {
            color: #0f172a;
        }

        .template-dark .panel-text,
        .template-dark .personal-name,
        .template-dark .detail-item span,
        .template-dark .profile-link span {
            color: #f1f5f9;
        }

        .template-tech .panel-text,
        .template-tech .personal-name,
        .template-tech .detail-item span,
        .template-tech .profile-link span {
            color: #e0f2fe;
        }

        .template-elegant .panel-text,
        .template-elegant .personal-name,
        .template-elegant .detail-item span,
        .template-elegant .profile-link span {
            color: #f8f0fc;
        }

        .template-corporate .panel-text,
        .template-corporate .personal-name,
        .template-corporate .detail-item span,
        .template-corporate .profile-link span {
            color: #1e293b;
        }

        .template-creative .panel-text,
        .template-creative .personal-name,
        .template-creative .detail-item span,
        .template-creative .profile-link span {
            color: #1e293b;
        }

        .template-3d .panel-text,
        .template-3d .personal-name,
        .template-3d .detail-item span,
        .template-3d .profile-link span {
            color: #66fcf1;
        }

        .template-neon .panel-text,
        .template-neon .personal-name,
        .template-neon .detail-item span,
        .template-neon .profile-link span {
            color: #ffffff;
        }

        /* ألوان الأيقونات حسب القالب */
        .template-modern .detail-item i { color: #667eea; }
        .template-classic .detail-item i { color: #94a3b8; }
        .template-minimal .detail-item i { color: #64748b; }
        .template-dark .detail-item i { color: #60a5fa; }
        .template-tech .detail-item i { color: #2dd4bf; }
        .template-elegant .detail-item i { color: #c084fc; }
        .template-corporate .detail-item i { color: #3b82f6; }
        .template-creative .detail-item i { color: #f97316; }
        .template-3d .detail-item i { color: #66fcf1; }
        .template-neon .detail-item i { color: #a78bfa; }

        /* خلفيات detail-item حسب القالب */
        .template-dark .detail-item {
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.15);
        }

        .template-tech .detail-item {
            background: rgba(45, 212, 191, 0.1);
            border: 1px solid rgba(45, 212, 191, 0.2);
        }

        .template-elegant .detail-item {
            background: rgba(192, 132, 252, 0.1);
            border: 1px solid rgba(192, 132, 252, 0.2);
        }

        .template-3d .detail-item {
            background: rgba(102, 252, 241, 0.1);
            border: 1px solid rgba(102, 252, 241, 0.2);
        }

        .template-neon .detail-item {
            background: rgba(167, 139, 250, 0.1);
            border: 1px solid rgba(167, 139, 250, 0.2);
        }

        /* ألوان الروابط الاجتماعية */
        .template-dark .social-links i {
            background: rgba(255, 255, 255, 0.15);
            color: #60a5fa;
        }

        .template-dark .qr-code {
            border-color: #60a5fa;
        }

        .template-dark .scan-code-text {
            color: #60a5fa;
        }

        .template-dark .profile-link {
            background: rgba(255, 255, 255, 0.15);
            border-color: rgba(255, 255, 255, 0.2);
        }

        .template-dark .copy-link-btn {
            color: #60a5fa;
        }

        .template-tech .social-links i {
            background: rgba(45, 212, 191, 0.15);
            color: #2dd4bf;
        }

        .template-elegant .social-links i {
            background: rgba(192, 132, 252, 0.15);
            color: #c084fc;
        }

        .template-3d .social-links i {
            background: rgba(102, 252, 241, 0.15);
            color: #66fcf1;
        }

        .template-3d .qr-code {
            border-color: #66fcf1;
        }

        .template-3d .scan-code-text {
            color: #66fcf1;
        }

        .template-3d .profile-link {
            background: rgba(102, 252, 241, 0.1);
            border-color: rgba(102, 252, 241, 0.3);
        }

        .template-3d .copy-link-btn {
            color: #66fcf1;
        }

        .template-neon .social-links i {
            background: rgba(167, 139, 250, 0.15);
            color: #a78bfa;
        }

        /* ألوان job-title-display و company-name-display في القوالب الداكنة */
        .template-dark .job-title-display,
        .template-dark .company-name-display,
        .template-tech .job-title-display,
        .template-tech .company-name-display,
        .template-elegant .job-title-display,
        .template-elegant .company-name-display,
        .template-3d .job-title-display,
        .template-3d .company-name-display,
        .template-neon .job-title-display,
        .template-neon .company-name-display {
            color: white;
        }

        /* ألوان personal-name في القوالب الداكنة */
        .template-dark .personal-name,
        .template-tech .personal-name,
        .template-elegant .personal-name,
        .template-3d .personal-name,
        .template-neon .personal-name {
            color: inherit;
        }

        /* خلفية profile-link حسب القالب */
        .template-modern .profile-link {
            background: rgba(102, 126, 234, 0.1);
            border-color: rgba(102, 126, 234, 0.2);
        }

        .template-classic .profile-link {
            background: rgba(45, 55, 72, 0.1);
            border-color: rgba(45, 55, 72, 0.2);
        }

        .template-minimal .profile-link {
            background: rgba(148, 163, 184, 0.1);
            border-color: rgba(148, 163, 184, 0.2);
        }

        .template-corporate .profile-link {
            background: rgba(59, 130, 246, 0.1);
            border-color: rgba(59, 130, 246, 0.2);
        }

        .template-creative .profile-link {
            background: rgba(249, 115, 22, 0.1);
            border-color: rgba(249, 115, 22, 0.2);
        }

        /* لون زر النسخ حسب القالب */
        .template-modern .copy-link-btn { color: #667eea; }
        .template-classic .copy-link-btn { color: #94a3b8; }
        .template-minimal .copy-link-btn { color: #64748b; }
        .template-tech .copy-link-btn { color: #2dd4bf; }
        .template-elegant .copy-link-btn { color: #c084fc; }
        .template-corporate .copy-link-btn { color: #3b82f6; }
        .template-creative .copy-link-btn { color: #f97316; }
        .template-neon .copy-link-btn { color: #a78bfa; }

        /* تصغير النصوص */
        @media (max-width: 800px) {
            .business-card { width: 600px; height: 350px; }
            .job-title-display { font-size: 28px; }
            .personal-name { font-size: 30px; }
            .detail-item { font-size: 16px; padding: 8px 15px; }
            .social-links i { font-size: 26px; }
        }

        @media (max-width: 650px) {
            .business-card { width: 500px; height: 450px; }
        }
    </style>
</head>
<body class="template-<%= template || 'modern' %>">

<div class="cards-wrapper">

    <!-- ========== الكرت الأول (المسمى الوظيفي يسار + البيانات يمين) ========== -->
    <div class="business-card card-primary">
        <!-- البانل الملون - الجهة اليسرى: المسمى الوظيفي واسم الشركة -->
        <div class="card-panel panel-colored">
            <div class="brand-content">
                <div class="job-title-display" id="jobTitle1"><%= formData.title || 'Job Title' %></div>
                <div class="company-name-display" id="companyName1"><%= formData.company || 'Company Name' %></div>
            </div>
        </div>

        <!-- البانل النصي - الجهة اليمنى: الاسم وبيانات الاتصال -->
        <div class="card-panel panel-text">
            <div class="info-content">
                <div class="personal-name" id="personalName1"><%= formData.name || 'H. SERISA' %></div>
                
                <div class="contact-details">
                    <div class="detail-item"><i class="fa fa-phone-alt"></i> <span id="phone1"><%= formData.phone || '+123 456 789' %></span></div>
                    <div class="detail-item"><i class="fa fa-envelope"></i> <span id="email1"><%= formData.email || 'your@mail.com' %></span></div>
                    <div class="detail-item"><i class="fa fa-globe"></i> <span id="website1"><%= formData.website || 'www.mail.com' %></span></div>
                    <div class="detail-item"><i class="fa fa-map-marker-alt"></i> <span id="address1"><%= formData.address || 'your street here' %></span></div>
                </div>
                
                <!-- رابط البطاقة الرقمية -->
                <div class="profile-link">
                    <span id="profileLink1"><%= profileUrl || 'https://nfc.pro/p/username' %></span>
                    <button class="copy-link-btn" onclick="copyProfileLink()"><i class="fa-regular fa-copy"></i></button>
                </div>
            </div>
        </div>

        <!-- الموجة الفاصلة -->
        <div class="wave-divider">
            <svg preserveAspectRatio="none" viewBox="0 0 120 420">
                <path d="M40 0 C90 80 90 340 40 420 L70 420 C120 340 120 80 70 0 Z" fill="#ffffff"/>
            </svg>
        </div>
    </div>

    <!-- ========== الكرت الثاني (المسمى الوظيفي يمين + باركود وأيقونات يسار) ========== -->
    <div class="business-card card-secondary">
        <!-- البانل الملون - الجهة اليمنى: المسمى الوظيفي واسم الشركة -->
        <div class="card-panel panel-colored">
            <div class="brand-content">
                <div class="job-title-display" id="jobTitle2"><%= formData.title || 'Job Title' %></div>
                <div class="company-name-display" id="companyName2"><%= formData.company || 'Company Name' %></div>
            </div>
        </div>

        <!-- البانل النصي - الجهة اليسرى: أيقونات وباركود -->
        <div class="card-panel panel-text">
            <div class="social-qr-section">
                <div class="social-links">
                    <% if (formData.facebook) { %>
                        <a href="<%= formData.facebook %>" target="_blank"><i class="fab fa-facebook-f"></i></a>
                    <% } else { %>
                        <i class="fab fa-facebook-f"></i>
                    <% } %>
                    
                    <% if (formData.instagram) { %>
                        <a href="<%= formData.instagram %>" target="_blank"><i class="fab fa-instagram"></i></a>
                    <% } else { %>
                        <i class="fab fa-instagram"></i>
                    <% } %>
                    
                    <% if (formData.twitter) { %>
                        <a href="<%= formData.twitter %>" target="_blank"><i class="fab fa-x-twitter"></i></a>
                    <% } else { %>
                        <i class="fab fa-x-twitter"></i>
                    <% } %>
                </div>
                
                <div class="qr-code" id="qrCodeContainer">
                    <img id="qrImage" src="https://api.qrserver.com/v1/create-qr-code/?size=110x110&data=<%= encodeURIComponent(profileUrl || 'https://nfc.pro') %>" alt="QR Code">
                </div>
                
                <div class="scan-code-text" onclick="downloadQR()">
                    <i class="fa-solid fa-download"></i> Scan Code
                </div>
                
                <!-- رابط البطاقة الرقمية -->
                <div class="profile-link" style="margin-top: 10px;">
                    <span id="profileLink2"><%= profileUrl || 'https://nfc.pro/p/username' %></span>
                    <button class="copy-link-btn" onclick="copyProfileLink()"><i class="fa-regular fa-copy"></i></button>
                </div>
            </div>
        </div>

        <!-- الموجة الفاصلة -->
        <div class="wave-divider">
            <svg preserveAspectRatio="none" viewBox="0 0 120 420">
                <path d="M40 0 C90 80 90 340 40 420 L70 420 C120 340 120 80 70 0 Z" fill="#ffffff"/>
            </svg>
        </div>
    </div>

</div>

<script>
    // استقبال المتغيرات من الخادم
    const profileId = '<%= profileId %>';
    const profileUrl = '<%= profileUrl %>';
    const whatsappNumber = '<%= whatsappNumber %>';
    const profileName = '<%= formData.name %>';
    const profileTitle = '<%= formData.title || "" %>';
    const profileCompany = '<%= formData.company || "" %>';
    const profileEmail = '<%= formData.email %>';
    const profilePhone = '<%= formData.phone %>';
    const profileAddress = '<%= formData.address || "" %>';
    const profileWebsite = '<%= formData.website || "" %>';
    const template = '<%= template || "modern" %>';

    console.log('📌 بيانات البطاقة:', { profileId, profileUrl, profileName, template });

    // تحديث البطاقات بالبيانات
    document.addEventListener('DOMContentLoaded', function() {
        // تحديث الكرت الأول
        document.getElementById('jobTitle1').textContent = profileTitle || 'Job Title';
        document.getElementById('companyName1').textContent = profileCompany || 'Company Name';
        document.getElementById('personalName1').textContent = profileName || 'H. SERISA';
        document.getElementById('phone1').textContent = profilePhone || '+123 456 789';
        document.getElementById('email1').textContent = profileEmail || 'your@mail.com';
        document.getElementById('website1').textContent = profileWebsite || 'www.mail.com';
        document.getElementById('address1').textContent = profileAddress || 'your street here';
        document.getElementById('profileLink1').textContent = profileUrl || 'https://nfc.pro/p/username';
        
        // تحديث الكرت الثاني
        document.getElementById('jobTitle2').textContent = profileTitle || 'Job Title';
        document.getElementById('companyName2').textContent = profileCompany || 'Company Name';
        document.getElementById('profileLink2').textContent = profileUrl || 'https://nfc.pro/p/username';
        
        // تحديث QR code
        if (profileUrl) {
            document.getElementById('qrImage').src = `https://api.qrserver.com/v1/create-qr-code/?size=110x110&data=${encodeURIComponent(profileUrl)}`;
        }
    });

    // نسخ الرابط
    function copyProfileLink() {
        const text = profileUrl || document.getElementById('profileLink1').textContent;
        navigator.clipboard.writeText(text).then(() => {
            alert('✅ تم نسخ الرابط: ' + text);
        }).catch(() => {
            const textarea = document.createElement('textarea');
            textarea.value = text;
            document.body.appendChild(textarea);
            textarea.select();
            document.execCommand('copy');
            document.body.removeChild(textarea);
            alert('✅ تم نسخ الرابط');
        });
    }

    // تنزيل QR code
    function downloadQR() {
        const qrUrl = document.getElementById('qrImage').src;
        window.open(qrUrl, '_blank');
    }

    // نسخ بيانات الاتصال عند النقر
    document.querySelectorAll('.detail-item').forEach(item => {
        item.addEventListener('click', function(e) {
            let text = this.innerText.replace(/[^0-9a-zA-Z@.:/]/g, '').trim();
            if (text) {
                navigator.clipboard?.writeText(text).then(() => {
                    alert('✅ تم النسخ: ' + text);
                });
            }
        });
    });

    // فتح روابط التواصل عند النقر على الأيقونات
    document.querySelectorAll('.social-links a').forEach(link => {
        link.addEventListener('click', function(e) {
            e.stopPropagation();
        });
    });
</script>

</body>
</html>